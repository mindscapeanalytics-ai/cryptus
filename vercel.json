{
  "headers": [
    {
      "source": "/(manifest.json|sw.js)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ],
  "regions": ["fra1"],
  "functions": {
    "app/api/screener/route.ts": {
      "maxDuration": 60
    },
    "app/api/cron/check-alerts/route.ts": {
      "maxDuration": 300
    }
  }
}
