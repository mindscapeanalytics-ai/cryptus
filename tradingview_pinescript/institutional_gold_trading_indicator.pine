ema_fast_len = input.int(50, "EMA Fast Length", minval=1, group=pro, tooltip="Fast EMA period for trend filter")
ema_slow_len = input.int(200, "EMA Slow Length", minval=1, group=pro, tooltip="Slow EMA period for trend filter")
rsi_len = input.int(14, "RSI Length", minval=1, group=pro, tooltip="RSI calculation period")
rsi_buy_min = input.int(52, "RSI Buy Minimum", minval=0, maxval=100, group=pro, tooltip="Minimum RSI for bullish momentum")
rsi_sell_max = input.int(48, "RSI Sell Maximum", minval=0, maxval=100, group=pro, tooltip="Maximum RSI for bearish momentum")
atr_len = input.int(14, "ATR Length", minval=1, group=pro, tooltip="ATR period for volatility measurement")
