text_size = input.string(size.tiny, "Text Size", options=[size.tiny, size.small, size.normal, size.large, size.huge], group=settings, tooltip="Size of text labels on chart")
delete_boxes = input.bool(true, "Delete Old/Broken Boxes", group=settings, tooltip="Remove invalidated zone boxes to keep chart clean")
manual_reset = input.bool(false, "Manual Reset Dashboard Signal", group=settings, tooltip="Check this to clear 'INVALIDATED' or 'ACTIVE' warnings from the dashboard manually. Uncheck after use.")

// =====================================================
// PRO INTELLIGENCE SETTINGS
// =====================================================
pro = "PRO Intelligence"
show_signals = input.bool(true, "Show Strong Buy/Sell Signals", group=pro, tooltip="Display high-probability trading signals")
show_vwap = input.bool(false, "Show VWAP", group=pro, tooltip="Display Volume Weighted Average Price (hidden by default for clean chart, logic still active)")
show_ema = input.bool(false, "Show EMA Trend Filter", group=pro, tooltip="Display fast and slow EMAs (hidden by default for clean chart, logic still active)")
show_rsi = input.bool(false, "Show RSI Panel Values in Labels", group=pro, tooltip="Include RSI value in signal labels")
show_sr = input.bool(false, "Show Support / Resistance", group=pro, tooltip="Display pivot-based S/R levels (hidden by default, logic still active)")
show_fvg = input.bool(true, "Show FVG", group=pro, tooltip="Display Fair Value Gaps")
show_pdh_pdl = input.bool(false, "Show PDH / PDL", group=pro, tooltip="Display Previous Day High and Low (often far away, causing chart compression)")
show_target_zone = input.bool(true, "Show Target Entry Zones", group=pro, tooltip="Highlight the specific zone price should touch for an entry")
use_volume_filter = input.bool(true, "Volume Confirmation", group=pro, tooltip="Require above-average volume for signals")
use_session_filter = input.bool(true, "Session Filter", group=pro, tooltip="Restrict signals to active trading session")
