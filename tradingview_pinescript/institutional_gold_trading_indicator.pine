indicator("Mindscape Analytics | Institutional Gold PRO+ (by Zeeshan Keerio)", "MA-Gold-PRO+", overlay=true, max_lines_count=500, max_labels_count=500, max_bars_back=4900, max_boxes_count=500)

// =====================================================
// SETTINGS GROUP
// =====================================================
settings = "Settings"
zigzag_len = input.int(9, "ZigZag Length", minval=5, maxval=20, group=settings, tooltip="Lookback period for swing detection (5-20 bars)")
show_zigzag = input.bool(false, "Show Zigzag", group=settings, tooltip="Display ZigZag lines connecting swing points (can cause chart compression)")
