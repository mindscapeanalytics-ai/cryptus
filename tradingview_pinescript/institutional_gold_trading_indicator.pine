// =====================================================
// INPUT VALIDATION
// =====================================================
// Clamp values to valid ranges
validated_zigzag_len = math.max(5, math.min(20, zigzag_len))
validated_fib_factor = math.max(0, math.min(1, fib_factor))
validated_rsi_buy_min = math.max(0, math.min(100, rsi_buy_min))
validated_rsi_sell_max = math.max(0, math.min(100, rsi_sell_max))
validated_score_scalp = math.max(0, math.min(15, score_threshold_scalp))
validated_score_intraday = math.max(0, math.min(15, score_threshold_intraday))
validated_score_swing = math.max(0, math.min(15, score_threshold_swing))

// =====================================================
// MARKET STRUCTURE STATE VARIABLES (Task 3.1)
// =====================================================
var float[] high_points_arr = array.new_float(5)
var int[] high_index_arr = array.new_int(5)
var float[] low_points_arr = array.new_float(5)
var int[] low_index_arr = array.new_int(5)

var int trend = 1  // 1=up, -1=down
var int market = 1  // 1=bullish, -1=bearish

// Box arrays for zone tracking (Tasks 5-6)
var box[] bu_ob_boxes = array.new_box()
var box[] be_ob_boxes = array.new_box()
var box[] bu_bb_boxes = array.new_box()
var box[] be_bb_boxes = array.new_box()
var box[] bu_fvg_boxes = array.new_box()
var box[] be_fvg_boxes = array.new_box()

// Box age tracking arrays (for time-based cleanup)
var int[] bu_ob_ages = array.new_int()
var int[] be_ob_ages = array.new_int()
var int[] bu_bb_ages = array.new_int()
var int[] be_bb_ages = array.new_int()
var int[] bu_fvg_ages = array.new_int()
var int[] be_fvg_ages = array.new_int()

// Bar index tracking for zones
var int bu_ob_index = bar_index
var int be_ob_index = bar_index
var int bu_bb_index = bar_index
var int be_bb_index = bar_index

// Support/Resistance state
var float last_support = na
var float last_resistance = na

// ── SIGNAL COOLDOWN STATE ─────────────────────────────
var int  last_buy_bar  = -999   // bar_index of last buy signal
var int  last_sell_bar = -999   // bar_index of last sell signal
var bool last_signal_was_buy = false  // track direction to prevent flip-flop

// =====================================================
// ADAPTIVE ATR STATE VARIABLES (Phase 1A Enhancement)
// =====================================================
// User-Defined Type for tracking each ATR factor's performance
type adaptive_atr_tracker
    float factor          // ATR multiplier (1.0, 1.5, 2.0, etc.)
    float perf = 0.0      // Performance score (EMA of returns)
    float upper           // SuperTrend upper band
    float lower           // SuperTrend lower band
    float output          // Current SuperTrend level
    int trend = 0         // Current trend (1=up, 0=down)

// K-means vector type for clustering (from LuxAlgo)
type kmeans_vector
    array<float> out

// Arrays to hold all factors being tested
var adaptive_atr_tracker[] atr_trackers = array.new<adaptive_atr_tracker>()
var float[] atr_test_factors = array.new_float()
var float adaptive_best_factor = 1.5  // Current best factor
var int adaptive_last_update = 0      // Last bar we updated

// K-means clustering state
var array<kmeans_vector> km_factor_clusters = na
var array<kmeans_vector> km_perf_clusters = na
var float km_target_factor = 1.5
var float km_perf_index = 0.0
var float km_perf_ama = na
var int km_supertrend_os = 0  // 1=bullish, 0=bearish

// Initialize factors array on first bar
if barstate.isfirst and use_adaptive_atr
    // Clear arrays
    array.clear(atr_test_factors)
    array.clear(atr_trackers)
    
    // Populate with factors to test
    for i = 0 to int((atr_max_factor - atr_min_factor) / atr_step)
        factor = atr_min_factor + i * atr_step
        array.push(atr_test_factors, factor)
        array.push(atr_trackers, adaptive_atr_tracker.new(factor=factor, upper=hl2, lower=hl2, output=hl2))

// =====================================================
// INTERNAL STRUCTURE STATE VARIABLES
// =====================================================
var float int_stru_up_axis = na
var float int_stru_dn_axis = na
var int int_stru_up_axis_bar = 0
var int int_stru_dn_axis_bar = 0
var int int_stru_upside_ready = 0
var int int_stru_downside_ready = 0
var int int_stru_moving = 0
var bool internal_bull_bos = false
var bool internal_bear_bos = false
var bool internal_bull_choch = false
var bool internal_bear_choch = false

// =====================================================
// VOLUME PROFILE STATE VARIABLES (Phase 2A)
// =====================================================
// Volume distribution array — sized to max possible rows to avoid out-of-bounds
// (vp_rows input max = 50; we allocate 50 slots and use vp_rows of them)
var float[] vp_volume_at_price = array.new_float(50, 0.0)

// Current profile levels
var float vp_poc_level = na
var float vp_vah_level = na
var float vp_val_level = na

// Profile period tracking
var float vp_period_high = high
var float vp_period_low = low
var int vp_period_start = bar_index
var int vp_last_calc_bar = 0

// Visual elements
var line vp_poc_line = na
var line vp_vah_line = na
var line vp_val_line = na

// =====================================================
// AREA OF INTEREST STATE VARIABLES (Phase 2B)
// =====================================================
// Price tracking arrays
var float[] aoe_close_arr = array.new_float()
var float[] aoe_open_arr = array.new_float()
var float[] aoe_high_arr = array.new_float()
var float[] aoe_low_arr = array.new_float()

// Current AOE levels
var float aoe_high = na
var float aoe_low = na
var int aoe_start_bar = bar_index

// Visual element
var box aoe_box = na

// Breakout tracking
var bool aoe_breakout_bull = false
var bool aoe_breakout_bear = false

// =====================================================
// HELPER FUNCTIONS
// =====================================================

// Safe array access for swing points
f_safe_get_float(arr, ind) =>
    array.size(arr) > ind ? array.get(arr, array.size(arr) - 1 - ind) : na

f_safe_get_int(arr, ind) =>
    array.size(arr) > ind ? array.get(arr, array.size(arr) - 1 - ind) : na

// Box deletion function with age tracking
f_delete_box_with_age(box_arr, age_arr) =>
    if array.size(box_arr) > 0 and array.size(age_arr) > 0
        bx = array.shift(box_arr)
        array.shift(age_arr)
        if delete_boxes and not na(bx)
            box.delete(bx)
    0

// Proximity check function
f_near(price, level, dist) =>
    not na(level) and math.abs(price - level) <= dist

// Timeframe-adaptive box extension
f_get_box_extension() =>
    tf_minutes = timeframe.in_seconds(timeframe.period) / 60
    extension = tf_minutes <= 15 ? 5 : tf_minutes <= 60 ? 8 : 10
    bar_index + extension

// =====================================================
// K-MEANS ADAPTIVE ATR FUNCTIONS (Phase 1A — LuxAlgo Upgrade)
// =====================================================

// =====================================================
// K-MEANS ADAPTIVE ATR ENGINE (Phase 1A — LuxAlgo Upgrade)
// =====================================================
// Runs in the global scope once per bar to ensure global state updates are valid
if use_adaptive_atr and array.size(atr_trackers) > 0 and bar_index > adaptive_last_update
    atr = ta.atr(atr_len)
    
    // --- Step 1: Update each factor's SuperTrend and performance ---
    for i = 0 to array.size(atr_trackers) - 1
        tracker = array.get(atr_trackers, i)
        
        up_val = hl2 + atr * tracker.factor
        dn_val = hl2 - atr * tracker.factor
        
        tracker.trend := close > tracker.upper ? 1 : close < tracker.lower ? 0 : tracker.trend
        tracker.upper := close[1] < tracker.upper ? math.min(up_val, tracker.upper) : up_val
        tracker.lower := close[1] > tracker.lower ? math.max(dn_val, tracker.lower) : dn_val
        tracker.output := tracker.trend == 1 ? tracker.lower : tracker.upper
        
        // Performance: EMA of returns aligned with trend
        diff_val = nz(math.sign(close[1] - tracker.output))
        alpha_val = 2 / (perf_memory + 1)
        tracker.perf += alpha_val * (nz(close - close[1]) * diff_val - tracker.perf)
    
    // --- Step 2: K-means clustering (3 clusters) ---
    perf_data = array.new_float(0)
    factor_data = array.new_float(0)
    
    for element in atr_trackers
        perf_data.push(element.perf)
        factor_data.push(element.factor)
    
    if perf_data.size() >= 3
        // Initialize centroids using quartiles
        var float[] centroids = array.new_float(3)
        centroids.set(0, perf_data.percentile_linear_interpolation(25))
        centroids.set(1, perf_data.percentile_linear_interpolation(50))
        centroids.set(2, perf_data.percentile_linear_interpolation(75))
        
        // Initialize global clusters if na
        if na(km_factor_clusters)
            km_factor_clusters := array.new<kmeans_vector>(3)
            km_perf_clusters   := array.new<kmeans_vector>(3)
            for i = 0 to 2
                km_factor_clusters.set(i, kmeans_vector.new(array.new_float(0)))
                km_perf_clusters.set(i, kmeans_vector.new(array.new_float(0)))

        // K-means iterations
        for _iter = 0 to 15 // Optimized for Pine performance
            // Clear cluster contents
            for i = 0 to 2
                km_factor_clusters.get(i).out.clear()
                km_perf_clusters.get(i).out.clear()
            
            // Assign each factor to nearest centroid
            for i = 0 to perf_data.size() - 1
                val = perf_data.get(i)
                d0 = math.abs(val - centroids.get(0))
                d1 = math.abs(val - centroids.get(1))
                d2 = math.abs(val - centroids.get(2))
                
                idx = d0 <= d1 and d0 <= d2 ? 0 : d1 <= d2 ? 1 : 2
                km_perf_clusters.get(idx).out.push(val)
                km_factor_clusters.get(idx).out.push(factor_data.get(i))
            
            // Update centroids
            c0 = km_perf_clusters.get(0).out.size() > 0 ? km_perf_clusters.get(0).out.avg() : centroids.get(0)
            c1 = km_perf_clusters.get(1).out.size() > 0 ? km_perf_clusters.get(1).out.avg() : centroids.get(1)
            c2 = km_perf_clusters.get(2).out.size() > 0 ? km_perf_clusters.get(2).out.avg() : centroids.get(2)
            
            converged = (c0 == centroids.get(0) and c1 == centroids.get(1) and c2 == centroids.get(2))
            centroids.set(0, c0)
            centroids.set(1, c1)
            centroids.set(2, c2)
            
            if converged
                break
        
        // Select best cluster (highest centroid = best performance)
        best_idx = centroids.get(0) >= centroids.get(1) and centroids.get(0) >= centroids.get(2) ? 0 : (centroids.get(1) >= centroids.get(2) ? 1 : 2)
        
        // Use average factor from best cluster
        best_cluster_factors = km_factor_clusters.get(best_idx).out
        adaptive_best_factor := best_cluster_factors.size() > 0 ? best_cluster_factors.avg() : 1.5
        
        // Store performance index for AMA
        den_ama = ta.ema(math.abs(close - close[1]), int(perf_memory))
        km_perf_index := den_ama > 0 ? math.max(nz(km_perf_clusters.get(best_idx).out.avg()), 0) / den_ama : 0

    adaptive_last_update := bar_index

// Adaptive factor access
current_adaptive_factor = use_adaptive_atr ? adaptive_best_factor : 1.5

// =====================================================
// VOLUME PROFILE CALCULATION FUNCTIONS (Phase 2A)
// =====================================================

// Calculate volume profile between structure breaks
f_calculate_volume_profile() =>
    if not use_volume_profile
        [na, na, na]
    else
        // Reset volume array
        for i = 0 to vp_rows - 1
            array.set(vp_volume_at_price, i, 0.0)
        
        // Calculate price range and step
        price_range = vp_period_high - vp_period_low
        
        if price_range <= 0
            [na, na, na]
        else
            price_step = price_range / vp_rows
            
            // Distribute volume across price levels
            bars_in_period = bar_index - vp_period_start
            lookback_bars = math.min(bars_in_period, vp_lookback)
            
            for i = 0 to lookback_bars
                bar_high = high[i]
                bar_low = low[i]
                bar_vol = volume[i]
                bar_range = bar_high - bar_low
                
                // Only process bars that overlap with the period range
                if bar_high >= vp_period_low and bar_low <= vp_period_high
                    // Find which price levels this bar touches
                    for level = 0 to vp_rows - 1
                        level_price_low = vp_period_low + level * price_step
                        level_price_high = vp_period_low + (level + 1) * price_step
                        
                        // Calculate overlap between bar and level
                        overlap_high = math.min(bar_high, level_price_high)
                        overlap_low = math.max(bar_low, level_price_low)
                        
                        if overlap_high >= overlap_low
                            // Calculate proportional volume for this level
                            overlap = overlap_high - overlap_low
                            vol_proportion = bar_range > 0 ? overlap / bar_range : 1.0 / vp_rows
                            
                            // Add volume to this level
                            current_vol = array.get(vp_volume_at_price, level)
                            array.set(vp_volume_at_price, level, current_vol + bar_vol * vol_proportion)
            
            // Find POC (level with maximum volume)
            max_vol = array.max(vp_volume_at_price)
            poc_index = array.indexof(vp_volume_at_price, max_vol)
            poc_price = vp_period_low + (poc_index + 0.5) * price_step
            
            // Calculate Value Area (68% of volume)
            total_volume = array.sum(vp_volume_at_price)
            target_volume = total_volume * (vp_value_area_pct / 100)
            
            // Start from POC and expand up/down
            va_volume = array.get(vp_volume_at_price, poc_index)
            va_high_idx = poc_index
            va_low_idx = poc_index
            
            // Expand Value Area until we reach target volume
            while va_volume < target_volume and (va_high_idx < vp_rows - 1 or va_low_idx > 0)
                vol_above = va_high_idx < vp_rows - 1 ? array.get(vp_volume_at_price, va_high_idx + 1) : 0
                vol_below = va_low_idx > 0 ? array.get(vp_volume_at_price, va_low_idx - 1) : 0
                
                // Expand toward higher volume
                if vol_above >= vol_below and va_high_idx < vp_rows - 1
                    va_high_idx += 1
                    va_volume += vol_above
                else if va_low_idx > 0
                    va_low_idx -= 1
                    va_volume += vol_below
                else
                    break
            
            // Calculate VAH and VAL prices
            vah_price = vp_period_low + (va_high_idx + 1) * price_step
            val_price = vp_period_low + va_low_idx * price_step
            
            [poc_price, vah_price, val_price]

// Check if price is near POC
f_near_poc(price, poc, dist) =>
    not na(poc) and math.abs(price - poc) <= dist

// Check if price is inside Value Area
f_inside_value_area(price, vah, val) =>
    not na(vah) and not na(val) and price <= vah and price >= val

// =====================================================
// CORE TECHNICAL INDICATORS
// =====================================================

// EMA Indicators (Task 2.1)
ema_fast = ta.ema(close, ema_fast_len)
ema_slow = ta.ema(close, ema_slow_len)

// RSI Indicator (Task 2.2)
rsi_val = ta.rsi(close, rsi_len)

// ATR Indicator (Task 2.3)
atr_val = ta.atr(atr_len)

// Ranging market detection (Robust)
atr_current  = ta.atr(14)
atr_long     = ta.atr(50)
is_ranging   = atr_current < atr_long * 0.6
trending_market = not is_ranging

// =====================================================
// ZIGZAG PIVOT DETECTION (Task 3.2)
// =====================================================

// Detect potential pivot points
to_up = high >= ta.highest(high, validated_zigzag_len)
to_down = low <= ta.lowest(low, validated_zigzag_len)

// Update trend direction
trend := nz(trend[1], 1)
trend := trend == 1 and to_down ? -1 : trend == -1 and to_up ? 1 : trend

// Calculate bars since last pivot
last_trend_up_since = ta.barssince(to_up[1])
low_val = ta.lowest(nz(last_trend_up_since > 0 ? last_trend_up_since : 1, 1))
low_index = bar_index - ta.barssince(low_val == low)

last_trend_down_since = ta.barssince(to_down[1])
high_val = ta.highest(nz(last_trend_down_since > 0 ? last_trend_down_since : 1, 1))
high_index = bar_index - ta.barssince(high_val == high)

// Record swing points when trend changes
if ta.change(trend) != 0
    if trend == 1
        array.push(low_points_arr, low_val)
        array.push(low_index_arr, low_index)
        // Maintain array size limit
        if array.size(low_points_arr) > 5
            array.shift(low_points_arr)
        if array.size(low_index_arr) > 5
            array.shift(low_index_arr)
    if trend == -1
        array.push(high_points_arr, high_val)
        array.push(high_index_arr, high_index)
        // Maintain array size limit
        if array.size(high_points_arr) > 5
            array.shift(high_points_arr)
        if array.size(high_index_arr) > 5
            array.shift(high_index_arr)

// Get swing point functions
f_get_high(ind) =>
    [f_safe_get_float(high_points_arr, ind), f_safe_get_int(high_index_arr, ind)]

f_get_low(ind) =>
    [f_safe_get_float(low_points_arr, ind), f_safe_get_int(low_index_arr, ind)]

// Get most recent swing points
[h0, h0i] = f_get_high(0)
[h1, h1i] = f_get_high(1)
[l0, l0i] = f_get_low(0)
[l1, l1i] = f_get_low(1)

// =====================================================
// MARKET STRUCTURE CLASSIFICATION (Task 3.3 & 3.4)
// =====================================================

// Track last recorded swing points for structure break detection
market := nz(market[1], 1)
last_l0 = ta.valuewhen(ta.change(market) != 0, l0, 0)
last_h0 = ta.valuewhen(ta.change(market) != 0, h0, 0)

// Market structure break detection with Body Close confirmation
// Bullish break (BOS/CHoCH): Body closes above previous high
// Bearish break (BOS/CHoCH): Body closes below previous low
is_bull_break = not na(h0) and close > h0 and close[1] <= h0 and (math.max(open, close) - math.min(open, close)) > (high - low) * 0.4
is_bear_break = not na(l0) and close < l0 and close[1] >= l0 and (math.max(open, close) - math.min(open, close)) > (high - low) * 0.4

market := last_l0 == l0 or last_h0 == h0 ? market : 
          market == 1  and is_bear_break ? -1 : 
          market == -1 and is_bull_break ? 1 : 
          market

// New structure break flag for signal generation
new_structure_break = ta.change(market) != 0

// MSB persistence — track last MSB bar and direction for dashboard visibility
var int last_msb_bar = 0
var int last_msb_dir = 0  // 1 = bullish, -1 = bearish
if new_structure_break
    last_msb_bar := bar_index
    last_msb_dir := market
msb_bars_ago = bar_index - last_msb_bar
msb_recent = msb_bars_ago <= 20  // Show MSB for 20 bars after it fires (Institutional Memory)

// =====================================================
// INTERNAL STRUCTURE DETECTION (Maxwell I-BoS/I-CHoCH)
// =====================================================
// Internal structure uses shorter pivot length for micro-level entry timing
// This provides earlier signals than external structure breaks

int_ph = ta.pivothigh(high, internal_sensitivity, internal_sensitivity)
int_pl = ta.pivotlow(low, internal_sensitivity, internal_sensitivity)

internal_bull_bos  := false
internal_bear_bos  := false
internal_bull_choch := false
internal_bear_choch := false

if show_internal_structure
    // Track internal swing highs
    if not na(int_ph)
        if int_ph > nz(int_stru_up_axis)
            // Higher high — continuation
            if int_stru_moving == -1
                internal_bull_choch := true
                if int_stru_type == "All" or int_stru_type == "CHoCH"
                    label.new(bar_index - internal_sensitivity, int_ph, "I-CHoCH", 
                         color=color.new(color.black, 100), style=label.style_label_down, 
                         textcolor=color.lime, size=size.tiny)
            else
                internal_bull_bos := true
                if int_stru_type == "All" or int_stru_type == "BoS"
                    label.new(bar_index - internal_sensitivity, int_ph, "I-BoS", 
                         color=color.new(color.black, 100), style=label.style_label_down, 
                         textcolor=color.green, size=size.tiny)
            int_stru_moving := 1
        int_stru_up_axis := int_ph
        int_stru_up_axis_bar := bar_index - internal_sensitivity
    
    // Track internal swing lows
    if not na(int_pl)
        if int_pl < nz(int_stru_dn_axis)
            // Lower low — continuation
            if int_stru_moving == 1
                internal_bear_choch := true
                if int_stru_type == "All" or int_stru_type == "CHoCH"
                    label.new(bar_index - internal_sensitivity, int_pl, "I-CHoCH", 
                         color=color.new(color.black, 100), style=label.style_label_up, 
                         textcolor=color.red, size=size.tiny)
            else
                internal_bear_bos := true
                if int_stru_type == "All" or int_stru_type == "BoS"
                    label.new(bar_index - internal_sensitivity, int_pl, "I-BoS", 
                         color=color.new(color.black, 100), style=label.style_label_up, 
                         textcolor=color.maroon, size=size.tiny)
            int_stru_moving := -1
        int_stru_dn_axis := int_pl
        int_stru_dn_axis_bar := bar_index - internal_sensitivity

// =====================================================
// K-MEANS SUPERTREND TRAILING STOP & PERFORMANCE AMA
// =====================================================
// Compute the trailing stop and Performance AMA from K-means clustering

current_factor = current_adaptive_factor
adaptive_atr = ta.atr(atr_len)

// SuperTrend trailing stop using K-means best factor
km_st_upper = hl2 + adaptive_atr * current_factor
km_st_lower = hl2 - adaptive_atr * current_factor
var float km_trailing_stop = na
var int km_trailing_trend = 0

km_trailing_trend := close > nz(km_trailing_stop, close) ? 1 : close < nz(km_trailing_stop, close) ? 0 : nz(km_trailing_trend, 1)
km_trailing_stop := km_trailing_trend == 1 ? 
     math.max(nz(km_trailing_stop, km_st_lower), km_st_lower) : 
     math.min(nz(km_trailing_stop, km_st_upper), km_st_upper)
km_supertrend_os := km_trailing_trend

// Performance AMA (Adaptive Moving Average from LuxAlgo)
// Uses performance index to dynamically set AMA speed
perf_alpha = math.pow(nz(km_perf_index), 2)
km_perf_ama := nz(km_perf_ama, close) + perf_alpha * (close - nz(km_perf_ama, close))

// Proximity check for trailing stop to prevent compression
ts_dist_limit = close * 0.01
plot(show_trailing_stop and use_adaptive_atr and math.abs(close - km_trailing_stop) < ts_dist_limit ? km_trailing_stop : na, "KM Trailing Stop", 
     color=km_supertrend_os == 1 ? color.new(color.lime, 30) : color.new(color.red, 30), linewidth=2, style=plot.style_linebr)
plot(show_perf_ama and use_adaptive_atr ? km_perf_ama : na, "Performance AMA", 
     color=color.new(color.aqua, 40), linewidth=1, style=plot.style_linebr)

// =====================================================
// SESSION BACKGROUND COLORING
// =====================================================
ny_session_active    = not na(time(timeframe.period, "0800-1700", "America/New_York"))
london_session_active = not na(time(timeframe.period, "0300-1200", "America/New_York"))
asia_session_active   = not na(time(timeframe.period, "1900-0400", "America/New_York"))

bgcolor(show_session_bg and ny_session_active ? color.new(ny_session_color, session_bg_transparency) : na, title="NY Session BG")
bgcolor(show_session_bg and london_session_active and not ny_session_active ? color.new(london_session_color, session_bg_transparency) : na, title="London Session BG")
bgcolor(show_session_bg and asia_session_active and not london_session_active and not ny_session_active ? color.new(asia_session_color, session_bg_transparency) : na, title="Asia Session BG")

// =====================================================
// VOLUME-WEIGHTED BAR COLORING
// =====================================================
vol_ma_ref = ta.sma(volume, vol_bar_ma_len)
vol_is_bold = volume > vol_ma_ref * vol_bar_bold_mult
vol_is_light = volume < vol_ma_ref * vol_bar_light_mult

bar_bull_color = vol_is_bold ? color.new(#00e676, 0) : vol_is_light ? color.new(#66bb6a, 70) : color.new(#4caf50, 30)
bar_bear_color = vol_is_bold ? color.new(#ff1744, 0) : vol_is_light ? color.new(#ef5350, 70) : color.new(#f44336, 30)
bar_vol_color = close >= open ? bar_bull_color : bar_bear_color

barcolor(use_vol_weighted_bars ? bar_vol_color : na, title="Volume-Weighted Bars")

// =====================================================
// AUTO FIBONACCI RETRACEMENT (from Maxwell)
// =====================================================
var line fib_line_1 = na
var line fib_line_2 = na
var line fib_line_3 = na
var line fib_line_4 = na
var line fib_line_5 = na

// Near-fib detection for scoring (from fib lines)
near_auto_fib_bull = false
near_auto_fib_bear = false

if show_auto_fibs and not na(h0) and not na(l0) and not na(h0i) and not na(l0i)
    fib_range_auto = h0 - l0
    if fib_range_auto > 0
        f1 = l0 + fib_range_auto * fib_level_1
        f2 = l0 + fib_range_auto * fib_level_2
        f3 = l0 + fib_range_auto * fib_level_3
        f4 = l0 + fib_range_auto * fib_level_4
        f5 = l0 + fib_range_auto * fib_level_5
        
        // Check if price is near any fib level
        fib_tolerance = atr_val * 0.3
        near_auto_fib_bull := f_near(close, f2, fib_tolerance) or f_near(close, f3, fib_tolerance) or f_near(close, f4, fib_tolerance)
        near_auto_fib_bear := f_near(close, f2, fib_tolerance) or f_near(close, f3, fib_tolerance) or f_near(close, f4, fib_tolerance)
        
        // Redraw fib lines on structure changes
        if new_structure_break
            // Clean up old lines
            line.delete(fib_line_1)
            line.delete(fib_line_2)
            line.delete(fib_line_3)
            line.delete(fib_line_4)
            line.delete(fib_line_5)
            
            // Only draw new fib lines if they are within proximity of price to prevent compression
            fib_dist_limit = close * 0.01
            right_bar = bar_index + 50
            if show_auto_fibs
                if math.abs(close - f1) < fib_dist_limit
                    fib_line_1 := line.new(l0i, f1, right_bar, f1, color=fib_color_1, style=line.style_dotted, width=1)
                if math.abs(close - f2) < fib_dist_limit
                    fib_line_2 := line.new(l0i, f2, right_bar, f2, color=fib_color_2, style=line.style_dashed, width=1)
                if math.abs(close - f3) < fib_dist_limit
                    fib_line_3 := line.new(l0i, f3, right_bar, f3, color=fib_color_3, style=line.style_solid, width=2)
                if math.abs(close - f4) < fib_dist_limit
                    fib_line_4 := line.new(l0i, f4, right_bar, f4, color=fib_color_4, style=line.style_dashed, width=1)
                if math.abs(close - f5) < fib_dist_limit
                    fib_line_5 := line.new(l0i, f5, right_bar, f5, color=fib_color_5, style=line.style_dotted, width=1)

// =====================================================
// VWAP Indicator (Task 2.4)
// =====================================================
vwap_val = ta.vwap(hlc3)

// Volume Confirmation (Task 2.5)
vol_sma = ta.sma(volume, 20)
vol_ok = volume > vol_sma

// Higher Timeframe Bias Analysis (Task 2.6) - Fixed Repainting
f_get_mtf_ema(tf, len) =>
    request.security(syminfo.tickerid, tf, ta.ema(close, len)[1], lookahead=barmerge.lookahead_on)

htf_ema = f_get_mtf_ema(htf_tf, htf_ema_len)
htf_close = request.security(syminfo.tickerid, htf_tf, close[1], lookahead=barmerge.lookahead_on)
htf_bull = htf_close > htf_ema
htf_bear = not htf_bull

// Session Filter
in_session = not use_session_filter or not na(time(timeframe.period, session_input))

// =====================================================
// GOLD-SPECIFIC INSTITUTIONAL LOGIC (ADVANCED TRICKS)
// =====================================================

// ── TRICK 1: ROUND NUMBER PSYCHOLOGY ──────────────────
// Institutions stack orders at $50 increments (3300, 3350, 3400…)
// Price acts like a magnet to these levels — trade WITH the magnet
round_number_base = 50
current_price_rounded = math.round(close / round_number_base) * round_number_base
distance_to_round = math.abs(close - current_price_rounded)
near_round_number = use_round_numbers and distance_to_round <= gold_round_number_dist
// Extra: detect $100 "century" levels — even stronger magnets
century_level = math.round(close / 100) * 100
near_century = math.abs(close - century_level) <= gold_round_number_dist * 1.5

// ── TRICK 1.1: DAILY BIAS (PDH/PDL) ───────────────────
// Gold often sweeps the previous day's high or low before reversing
pdh = request.security(syminfo.tickerid, "D", high[1], lookahead=barmerge.lookahead_on)
pdl = request.security(syminfo.tickerid, "D", low[1], lookahead=barmerge.lookahead_on)
pdm = (pdh + pdl) / 2
near_pdh = f_near(high, pdh, atr_val * 0.3)
near_pdl = f_near(low, pdl, atr_val * 0.3)
sweep_pdh = high > pdh and close < pdh
sweep_pdl = low < pdl and close > pdl

// ── TRICK 2: GOLD VOLATILITY FILTER ───────────────────
// Gold ATR spikes 3-5x on NFP/CPI/FOMC — avoid those candles
atr_sma_20 = ta.sma(atr_val, 20)
extreme_volatility = use_gold_volatility and (use_adaptive_atr ? atr_val > atr_sma_20 * (current_adaptive_factor * 0.8) : atr_val > atr_sma_20 * gold_volatility_mult)
normal_volatility = not extreme_volatility

// ── TRICK 3: SESSION INTELLIGENCE ─────────────────────
// Gold has 3 distinct sessions with different behaviour:
//   Asian  00-07 UTC : thin, choppy, avoid
//   London 07-12 UTC : trend initiation, good for breakouts
//   NY     13-17 UTC : highest volume, best for reversals
hour_utc = hour(time, "UTC")
in_asian_session  = hour_utc >= 0  and hour_utc < 7
in_london_session = hour_utc >= 7  and hour_utc < 12
in_ny_session     = hour_utc >= 13 and hour_utc < 17
in_prime_session  = in_london_session or in_ny_session   // best liquidity windows
avoid_asian       = use_asian_session_filter ? not in_asian_session : true
prime_session_bonus = in_prime_session ? 1 : 0

// ── TRICK 3.1: ICT SILVER BULLET (GOLD HACK) ──────────
// High-probability 1-hour windows for Gold volatility
is_london_silver_bullet = hour_utc == 7  // 07:00-08:00 UTC
is_ny_silver_bullet     = hour_utc == 15 // 15:00-16:00 UTC (Updated for 2026 NY cycle)
is_silver_bullet        = is_london_silver_bullet or is_ny_silver_bullet
silver_bullet_bonus     = is_silver_bullet ? 3 : 0 // Increased weighting for SB

// ── TRICK 3.2: INSTITUTIONAL ROUND NUMBERS ────────────
// Institutions place massive orders at .00 and .50 levels
f_is_round_number(val) =>
    rem = val % 1.0
    math.abs(rem - 0.0) < 0.05 or math.abs(rem - 0.5) < 0.05 or math.abs(rem - 1.0) < 0.05

near_round_num = f_is_round_number(close)
round_num_bonus = near_round_num ? 1 : 0

// ── TRICK 4: NEWS EVENT BUFFER ────────────────────────
// Rapid ATR expansion = news incoming — stand aside
atr_rising = atr_val > atr_val[1] and atr_val[1] > atr_val[2]
potential_news_event = use_news_buffer and atr_rising and extreme_volatility
safe_to_trade = not potential_news_event

// ── TRICK 5: INSTITUTIONAL FLOW VIA VWAP ──────────────
// VWAP is the benchmark price for institutional execution desks
// Session-anchored VWAP (ta.vwap) is the institutional standard
// Deviation bands detect overextended price from fair value
vwap_stdev = ta.stdev(close, 100)
vwap_upper_1 = vwap_val + vwap_stdev
vwap_lower_1 = vwap_val - vwap_stdev
vwap_upper_2 = vwap_val + vwap_stdev * 2
vwap_lower_2 = vwap_val - vwap_stdev * 2

gold_institutional_flow = close > vwap_val
gold_institutional_sell = close < vwap_val
is_overbought_vwap = close > vwap_upper_2
is_oversold_vwap   = close < vwap_lower_2

// ── TRICK 5.1: DXY INVERSE CORRELATION (ULTRA-ADVANCED) 
// Gold and US Dollar Index (DXY) are ~85% inversely correlated
// If DXY is trending UP, Gold longs are high-risk
dxy_close = request.security(dxy_symbol, timeframe.period, close[1], lookahead=barmerge.lookahead_on)
dxy_ema   = ta.ema(nz(dxy_close, close), 20)
dxy_bullish = nz(dxy_close) > nz(dxy_ema)
dxy_bearish = nz(dxy_close) < nz(dxy_ema)
gold_long_allowed  = dxy_bearish or na(dxy_close) // Soften roadblock if DXY missing
gold_short_allowed = dxy_bullish or na(dxy_close)

// ── TRICK 6: GOLD MOMENTUM DIVERGENCE (RSI) ───────────
// RSI divergence on gold is highly reliable for reversals
// Bullish: price lower low, RSI higher low → hidden strength
// Bearish: price higher high, RSI lower high → hidden weakness
rsi_prev_low  = ta.lowest(rsi_val, 14)
rsi_prev_high = ta.highest(rsi_val, 14)
price_lower_low_rsi  = low  < ta.lowest(low[1],  10) and rsi_val > rsi_prev_low[1]
price_higher_high_rsi = high > ta.highest(high[1], 10) and rsi_val < rsi_prev_high[1]
rsi_bullish_div = price_lower_low_rsi  and rsi_val < 45   // oversold divergence
rsi_bearish_div = price_higher_high_rsi and rsi_val > 55  // overbought divergence

// ── TRICK 7: GOLD OPEN INTEREST PROXY ─────────────────
// When volume surges AND price barely moves = accumulation/distribution
// This is how institutions build positions without moving price
vol_surge = volume > vol_sma * 2.5
price_range_small = (high - low) < atr_val * 0.6
institutional_accumulation = vol_surge and price_range_small and close > open
institutional_distribution = vol_surge and price_range_small and close < open

// ── TRICK 8: GOLD FIBONACCI CONFLUENCE ────────────────
// Gold respects 0.618 and 0.786 retracements extremely well
// Calculate fib levels from recent swing high/low
// (used later in scoring after h0/l0 are defined)

// ── TRICK 9: GOLD SPREAD / MOMENTUM FILTER ────────────
// Strong momentum candles on gold = institutional participation
// Body > 60% of range AND close near high/low = conviction
gold_bull_momentum_candle = close > open and (close - open) > (high - low) * 0.55 and close > (high + low) / 2 + atr_val * 0.1
gold_bear_momentum_candle = close < open and (open - close) > (high - low) * 0.55 and close < (high + low) / 2 - atr_val * 0.1

// ── TRICK 10: GOLD CONSOLIDATION BREAKOUT ─────────────
// Gold consolidates in tight ranges then explodes — detect the squeeze
highest_20 = ta.highest(high, 20)
lowest_20  = ta.lowest(low,  20)
range_20   = highest_20 - lowest_20
atr_20_avg = ta.sma(atr_val, 20)
in_squeeze = range_20 < atr_20_avg * 3.0   // tight consolidation
breakout_up   = in_squeeze[1] and close > highest_20[1] and close > open
breakout_down = in_squeeze[1] and close < lowest_20[1]  and close < open

// ── TRICK 11: POWER OF 3 (PO3) DAILY CYCLE ────────────
// Accumulation (Asian), Manipulation (London), Distribution (NY)
is_accumulation  = in_asian_session
is_manipulation = in_london_session and (low < pdl or high > pdh) // Stop hunt beyond PDH/PDL
is_distribution = in_ny_session and trending_market

// Combine patterns
gold_conditions_ok = normal_volatility and avoid_asian and safe_to_trade

// =====================================================
// 🔥 ADVANCED PROFESSIONAL SYSTEMS
// =====================================================

// ── 1. SMART MONEY DIVERGENCE ─────────────────────────
// Price/volume divergence = institutions quietly accumulating or distributing
vol_ma_fast = ta.sma(volume, 10)
vol_ma_slow = ta.sma(volume, 30)
price_making_higher_high = high > ta.highest(high[1], 10)
price_making_lower_low   = low  < ta.lowest(low[1],  10)
volume_declining  = vol_ma_fast < vol_ma_slow
volume_increasing = vol_ma_fast > vol_ma_slow

bullish_divergence = use_smart_money_divergence and price_making_lower_low  and volume_declining  and close > open
bearish_divergence = use_smart_money_divergence and price_making_higher_high and volume_declining  and close < open

// ── 2. MULTI-TIMEFRAME CONFLUENCE ─────────────────────
// All 3 timeframes must agree — eliminates counter-trend noise
// Using [1] offset to prevent repainting
f_mtf_trend(tf) =>
    _ema = ta.ema(close, 50)
    request.security(syminfo.tickerid, tf, close[1] > _ema[1], lookahead=barmerge.lookahead_on)

mtf_15m_trend = f_mtf_trend("15")
mtf_1h_trend  = f_mtf_trend("60")
mtf_4h_trend  = f_mtf_trend("240")

mtf_bullish_confluence = use_mtf_confluence ? (mtf_15m_trend  and mtf_1h_trend  and mtf_4h_trend)  : true
mtf_bearish_confluence = use_mtf_confluence ? (not mtf_15m_trend and not mtf_1h_trend and not mtf_4h_trend) : true

// ── 3. MARKET REGIME DETECTION ────────────────────────
// Adapt thresholds to current market character
atr_lo = ta.lowest(atr_val, 100)
atr_hi = ta.highest(atr_val, 100)
atr_range = atr_hi - atr_lo
atr_percentile = atr_range > 0 ? (atr_val - atr_lo) / atr_range * 100 : 50
regime_trending = atr_percentile > 60
regime_ranging  = atr_percentile < 40
regime_volatile = atr_percentile > 80
regime_multiplier = regime_trending ? 1.0 : regime_ranging ? 1.2 : 0.85

// ── 4. INSTITUTIONAL ORDER FLOW ───────────────────────
// Large candle + high volume = institutional participation
large_candle       = (high - low) > atr_val * 1.5
high_volume_candle = volume > vol_sma * 2.0
institutional_candle = large_candle and high_volume_candle
bullish_order_flow = institutional_candle and close > open and close > (high + low) / 2
bearish_order_flow = institutional_candle and close < open and close < (high + low) / 2

// ── 5. LIQUIDITY GRAB CONFIRMATION ────────────────────
// Stop hunt: price spikes through a level then snaps back
// This is the #1 institutional entry technique on gold
wick_size_up   = high - math.max(open, close)
wick_size_down = math.min(open, close) - low
body_size      = math.abs(close - open)
candle_range   = high - low

// Bullish grab: long lower wick sweeps sell stops, then closes bullish
liquidity_grab_bullish = use_liquidity_grab and wick_size_down > body_size * 1.8 and close > open and low < ta.lowest(low[1], 5)
// Bearish grab: long upper wick sweeps buy stops, then closes bearish
liquidity_grab_bearish = use_liquidity_grab and wick_size_up > body_size * 1.8 and close < open and high > ta.highest(high[1], 5)

// ── 6. ADVANCED CANDLE PATTERNS ───────────────────────
// Engulfing (most reliable on gold)
bullish_engulfing = close > open and close[1] < open[1] and close > open[1] and open < close[1] and body_size > atr_val * 0.3
bearish_engulfing = close < open and close[1] > open[1] and close < open[1] and open > close[1] and body_size > atr_val * 0.3

// Morning / Evening star (3-bar reversal)
doji_body = math.abs(close[1] - open[1]) < atr_val * 0.15
morning_star = close[2] < open[2] and doji_body and close > open and close > (open[2] + close[2]) / 2
evening_star = close[2] > open[2] and doji_body and close < open and close < (open[2] + close[2]) / 2

// Hammer / Shooting star
hammer       = wick_size_down > body_size * 2.0 and wick_size_up < body_size * 0.5 and close > open
shooting_star = wick_size_up  > body_size * 2.0 and wick_size_down < body_size * 0.5 and close < open

// Three soldiers / crows (trend continuation)
three_white_soldiers = close > open and close[1] > open[1] and close[2] > open[2] and close > close[1] and close[1] > close[2]
three_black_crows    = close < open and close[1] < open[1] and close[2] < open[2] and close < close[1] and close[1] < close[2]

// Pin bar (strong rejection — very reliable on gold)
pin_bar_bull = wick_size_down > candle_range * 0.6 and close > (high + low) / 2
pin_bar_bear = wick_size_up   > candle_range * 0.6 and close < (high + low) / 2

// Inside bar breakout (compression before expansion)
inside_bar = high < high[1] and low > low[1]
inside_bar_bull_break = inside_bar[1] and close > high[1] and close > open
inside_bar_bear_break = inside_bar[1] and close < low[1]  and close < open

// ── 7. SWING FAILURE PATTERN (SFP) ───────────────────
// Price sweeps a high/low but fails to close above/below it
// Highly effective institutional reversal signal on Gold
sfp_bullish = low < ta.lowest(low[1], 5) and close > ta.lowest(low[1], 5) and close > open
sfp_bearish = high > ta.highest(high[1], 5) and close < ta.highest(high[1], 5) and close < open

// SFP persistence — track last SFP for dashboard visibility (20-bar window for institutional setups)
var int last_sfp_bar = 0
var int last_sfp_dir = 0  // 1 = bullish, -1 = bearish
if sfp_bullish
    last_sfp_bar := bar_index
    last_sfp_dir := 1
if sfp_bearish
    last_sfp_bar := bar_index
    last_sfp_dir := -1
sfp_bars_ago = bar_index - last_sfp_bar
sfp_recent = sfp_bars_ago <= 20

// ── 8. EQUAL HIGHS / LOWS (LIQUIDITY TARGETS) ────────
// Detect nearly identical highs/lows where stops are stacked
is_eql = not na(l0) and not na(l1) and math.abs(l0 - l1) < atr_val * 0.15
is_eqh = not na(h0) and not na(h1) and math.abs(h0 - h1) < atr_val * 0.15

// Combine patterns
bullish_pattern = use_advanced_patterns and (bullish_engulfing or morning_star or hammer or three_white_soldiers or pin_bar_bull or inside_bar_bull_break or sfp_bullish)
bearish_pattern = use_advanced_patterns and (bearish_engulfing or evening_star or shooting_star or three_black_crows or pin_bar_bear or inside_bar_bear_break or sfp_bearish)


// =====================================================
// PLACEHOLDER FOR REMAINING COMPONENTS
// =====================================================
// Market structure detection will be implemented in Task 3
// Zone detection will be implemented in Tasks 5-6
// Confluence scoring will be implemented in Task 12
// Signal generation will be implemented in Task 13
// Visual rendering will be implemented in Tasks 16-18


// =====================================================
// ZIGZAG LINE VISUALIZATION (Task 3.5)
// =====================================================

// Draw ZigZag lines connecting swing points
if ta.change(trend) != 0 and show_zigzag and not na(h0i) and not na(h1i) and not na(l0i) and not na(l1i)
    if trend == 1
        // Bullish leg: connect high to low (green)
        line.new(h0i, h0, l0i, l0, width=1, color=color.new(color.green, 0))
    if trend == -1
        // Bearish leg: connect low to high (red)
        line.new(l0i, l0, h0i, h0, width=1, color=color.new(color.red, 0))

// =====================================================
// ORDER BLOCK DETECTION (Tasks 5.2 & 5.3)
// =====================================================

// Update order block indices on each bar
bu_ob_index := nz(bu_ob_index[1], bar_index)
be_ob_index := nz(be_ob_index[1], bar_index)

// Detect order blocks on market structure breaks
if ta.change(market) != 0
    if market == 1 and not na(h1i) and not na(l0i)
        // Bullish Order Block: Last bearish candle before bullish displacement
        search_start = int(math.max(0, bar_index - h1i))
        search_end = int(math.max(0, bar_index - l0i))
        for i = search_start to search_end
            // Check for bearish candle followed by bullish displacement
            if i < bar_index and open[i] > close[i]
                displacement = (close[i-1] - open[i-1]) > atr_val[i] * 0.5
                if displacement
                    bu_ob_index := bar_index - i
    
    if market == -1 and not na(l1i) and not na(h0i)
        // Bearish Order Block: Last bullish candle before bearish displacement
        search_start = int(math.max(0, bar_index - l1i))
        search_end = int(math.max(0, bar_index - h0i))
        for i = search_start to search_end
            // Check for bullish candle followed by bearish displacement
            if i < bar_index and open[i] < close[i]
                displacement = (open[i-1] - close[i-1]) > atr_val[i] * 0.5
                if displacement
                    be_ob_index := bar_index - i

// Calculate bars since order block
bu_ob_since = bar_index - bu_ob_index
be_ob_since = bar_index - be_ob_index

// =====================================================
// BREAKER BLOCK DETECTION (Tasks 5.6 & 5.7)
// =====================================================

// Update breaker block indices
bu_bb_index := nz(bu_bb_index[1], bar_index)
be_bb_index := nz(be_bb_index[1], bar_index)

// Detect breaker blocks on market structure breaks
if ta.change(market) != 0
    if market == 1 and not na(l1i) and not na(h1i)
        // Bullish Breaker Block
        search_start = int(math.max(0, bar_index - l1i - validated_zigzag_len))
        search_end = int(math.max(0, bar_index - h1i))
        for i = search_start to search_end
            if i < bar_index and open[i] < close[i]
                bu_bb_index := bar_index - i
    
    if market == -1 and not na(h1i) and not na(l1i)
        // Bearish Breaker Block
        search_start = int(math.max(0, bar_index - h1i - validated_zigzag_len))
        search_end = int(math.max(0, bar_index - l1i))
        for i = search_start to search_end
            if i < bar_index and open[i] > close[i]
                be_bb_index := bar_index - i

// Calculate bars since breaker block
bu_bb_since = bar_index - bu_bb_index
be_bb_since = bar_index - be_bb_index

// =====================================================
// ORDER BLOCK & BREAKER BLOCK BOX CREATION (Tasks 5.4 & 5.8)
// =====================================================

// Create boxes on market structure breaks
if ta.change(market) != 0 and not na(h1i) and not na(l0i) and not na(l1i) and not na(h0i)
    box_right = f_get_box_extension()
    
    if market == 1
        // Bullish market structure break
        // Create bullish order block box
        bu_ob = box.new(bu_ob_index, high[bu_ob_since], box_right, low[bu_ob_since], bgcolor=bu_ob_color, border_color=bu_ob_border_color, text="Bu-OB", text_color=bu_ob_text_color, text_halign=text.align_right)
        array.push(bu_ob_boxes, bu_ob)
        array.push(bu_ob_ages, bar_index)
        
        // Create bullish breaker block box (only if enabled)
        if show_breaker_blocks
            bu_bb = box.new(bu_bb_index, high[bu_bb_since], box_right, low[bu_bb_since], bgcolor=bu_bb_color, border_color=bu_bb_border_color, text=l0 < l1 ? "Bu-BB" : "Bu-MB", text_color=bu_bb_text_color, text_halign=text.align_right)
            array.push(bu_bb_boxes, bu_bb)
            array.push(bu_bb_ages, bar_index)
        
        // Draw market structure break line
        line.new(h1i, h1, h0i, h1, color=color.green, width=2)
        label.new(int(math.avg(h1i, l0i)), h1, "MSB", color=color.new(color.black, 100), style=label.style_label_down, textcolor=color.green, size=text_size)
    
    if market == -1
        // Bearish market structure break
        // Create bearish order block box
        be_ob = box.new(be_ob_index, high[be_ob_since], box_right, low[be_ob_since], bgcolor=be_ob_color, border_color=be_ob_border_color, text="Be-OB", text_color=be_ob_text_color, text_halign=text.align_right)
        array.push(be_ob_boxes, be_ob)
        array.push(be_ob_ages, bar_index)
        
        // Create bearish breaker block box (only if enabled)
        if show_breaker_blocks
            be_bb = box.new(be_bb_index, high[be_bb_since], box_right, low[be_bb_since], bgcolor=be_bb_color, border_color=be_bb_border_color, text=h0 > h1 ? "Be-BB" : "Be-MB", text_color=be_bb_text_color, text_halign=text.align_right)
            array.push(be_bb_boxes, be_bb)
            array.push(be_bb_ages, bar_index)
        
        // Draw market structure break line
        line.new(l1i, l1, l0i, l1, color=color.red, width=2)
        label.new(int(math.avg(l1i, h0i)), l1, "MSB", color=color.new(color.black, 100), style=label.style_label_up, textcolor=color.red, size=text_size)

// Redundant tracking removed (using global MSB logic at line 706)

// =====================================================
// ORDER BLOCK & BREAKER BLOCK MAINTENANCE (Task 5.5) + AGGRESSIVE CLEANUP
// =====================================================

// Maintain bullish order blocks with age-based cleanup
if array.size(bu_ob_boxes) > 0
    for i = array.size(bu_ob_boxes) - 1 to 0
        bull_ob = array.get(bu_ob_boxes, i)
        box_age = bar_index - array.get(bu_ob_ages, i)
        bottom = box.get_bottom(bull_ob)
        top = box.get_top(bull_ob)
        
        // Age-based cleanup
        should_delete = box_age > max_box_age
        
        // Price invalidation
        if close < bottom
            should_delete := true
        
        // Aggressive cleanup mode - remove if too many boxes
        if aggressive_cleanup and array.size(bu_ob_boxes) > max_boxes_per_type
            should_delete := true
        
        if should_delete
            array.remove(bu_ob_boxes, i)
            array.remove(bu_ob_ages, i)
            if delete_boxes
                box.delete(bull_ob)
        else if close < top
            // Price in zone - alert and extend
            alert("Price in the BU-OB zone")
            box.set_right(bull_ob, f_get_box_extension())
        else
            // Still valid - extend
            box.set_right(bull_ob, f_get_box_extension())

// Maintain bearish order blocks with age-based cleanup
if array.size(be_ob_boxes) > 0
    for i = array.size(be_ob_boxes) - 1 to 0
        bear_ob = array.get(be_ob_boxes, i)
        box_age = bar_index - array.get(be_ob_ages, i)
        top = box.get_top(bear_ob)
        bottom = box.get_bottom(bear_ob)
        
        // Age-based cleanup
        should_delete = box_age > max_box_age
        
        // Price invalidation
        if close > top
            should_delete := true
        
        // Aggressive cleanup mode
        if aggressive_cleanup and array.size(be_ob_boxes) > max_boxes_per_type
            should_delete := true
        
        if should_delete
            array.remove(be_ob_boxes, i)
            array.remove(be_ob_ages, i)
            if delete_boxes
                box.delete(bear_ob)
        else if close > bottom
            // Price in zone - alert and extend
            alert("Price in the BE-OB zone")
            box.set_right(bear_ob, f_get_box_extension())
        else
            // Still valid - extend
            box.set_right(bear_ob, f_get_box_extension())

// Maintain bullish breaker blocks (only if enabled)
if show_breaker_blocks and array.size(bu_bb_boxes) > 0
    for i = array.size(bu_bb_boxes) - 1 to 0
        bull_bb = array.get(bu_bb_boxes, i)
        box_age = bar_index - array.get(bu_bb_ages, i)
        bottom = box.get_bottom(bull_bb)
        top = box.get_top(bull_bb)
        
        should_delete = box_age > max_box_age or close < bottom
        if aggressive_cleanup and array.size(bu_bb_boxes) > max_boxes_per_type
            should_delete := true
        
        if should_delete
            array.remove(bu_bb_boxes, i)
            array.remove(bu_bb_ages, i)
            if delete_boxes
                box.delete(bull_bb)
        else if close < top
            alert("Price in the BU-BB zone")
            box.set_right(bull_bb, f_get_box_extension())
        else
            box.set_right(bull_bb, f_get_box_extension())

// Maintain bearish breaker blocks (only if enabled)
if show_breaker_blocks and array.size(be_bb_boxes) > 0
    for i = array.size(be_bb_boxes) - 1 to 0
        bear_bb = array.get(be_bb_boxes, i)
        box_age = bar_index - array.get(be_bb_ages, i)
        top = box.get_top(bear_bb)
        bottom = box.get_bottom(bear_bb)
        
        should_delete = box_age > max_box_age or close > top
        if aggressive_cleanup and array.size(be_bb_boxes) > max_boxes_per_type
            should_delete := true
        
        if should_delete
            array.remove(be_bb_boxes, i)
            array.remove(be_bb_ages, i)
            if delete_boxes
                box.delete(bear_bb)
        else if close > bottom
            alert("Price in the BE-BB zone")
            box.set_right(bear_bb, f_get_box_extension())
        else
            box.set_right(bear_bb, f_get_box_extension())

// =====================================================
// FAIR VALUE GAP DETECTION (Tasks 6.2, 6.3, 6.4) + AGE TRACKING
// =====================================================

// Bullish FVG: Current low > high from 2 bars ago
bull_fvg = low > high[2]

// Bearish FVG: Current high < low from 2 bars ago
bear_fvg = high < low[2]

// Create FVG boxes with age tracking
if show_fvg and bull_fvg
    box_right = f_get_box_extension()
    b = box.new(bar_index - 2, high[2], box_right, low, bgcolor=color.new(color.green, 88), border_color=color.new(color.green, 40), text="Bu-FVG", text_color=color.new(color.green, 0))
    array.push(bu_fvg_boxes, b)
    array.push(bu_fvg_ages, bar_index)

if show_fvg and bear_fvg
    box_right = f_get_box_extension()
    b = box.new(bar_index - 2, high, box_right, low[2], bgcolor=color.new(color.red, 88), border_color=color.new(color.red, 40), text="Be-FVG", text_color=color.new(color.red, 0))
    array.push(be_fvg_boxes, b)
    array.push(be_fvg_ages, bar_index)

// =====================================================
// FVG MAINTENANCE (Task 6.5) + AGGRESSIVE CLEANUP
// =====================================================

// Maintain bullish FVGs with age-based cleanup
if array.size(bu_fvg_boxes) > 0
    for i = array.size(bu_fvg_boxes) - 1 to 0
        fvg = array.get(bu_fvg_boxes, i)
        box_age = bar_index - array.get(bu_fvg_ages, i)
        top = box.get_top(fvg)
        bot = box.get_bottom(fvg)
        
        // Age-based cleanup (FVGs expire faster than order blocks)
        should_delete = box_age > (max_box_age / 2) or close < bot
        
        // Aggressive cleanup mode
        if aggressive_cleanup and array.size(bu_fvg_boxes) > max_boxes_per_type
            should_delete := true
        
        if should_delete
            array.remove(bu_fvg_boxes, i)
            array.remove(bu_fvg_ages, i)
            if delete_boxes
                box.delete(fvg)
        else
            // Still valid - extend
            box.set_right(fvg, f_get_box_extension())

// Maintain bearish FVGs with age-based cleanup
if array.size(be_fvg_boxes) > 0
    for i = array.size(be_fvg_boxes) - 1 to 0
        fvg = array.get(be_fvg_boxes, i)
        box_age = bar_index - array.get(be_fvg_ages, i)
        top = box.get_top(fvg)
        bot = box.get_bottom(fvg)
        
        // Age-based cleanup (FVGs expire faster)
        should_delete = box_age > (max_box_age / 2) or close > top
        
        // Aggressive cleanup mode
        if aggressive_cleanup and array.size(be_fvg_boxes) > max_boxes_per_type
            should_delete := true
        
        if should_delete
            array.remove(be_fvg_boxes, i)
            array.remove(be_fvg_ages, i)
            if delete_boxes
                box.delete(fvg)
        else
            // Still valid - extend
            box.set_right(fvg, f_get_box_extension())

// =====================================================
// LIQUIDITY ANALYSIS (Task 7.1 & 7.2)
// =====================================================

// Liquidity sweep detection
liq_high_sweep = high > ta.highest(high[1], 5)
liq_low_sweep = low < ta.lowest(low[1], 5)

// Zone proximity calculation
zone_dist = use_adaptive_atr ? atr_val * (current_adaptive_factor * 0.5) : atr_val * zone_atr_mult

// =====================================================
// VOLUME PROFILE CALCULATION TRIGGER (Phase 2A)
// =====================================================
// Recalculate on every market structure break; update period bounds every bar
if ta.change(market) != 0 and use_volume_profile
    // Calculate profile for the period that just ended
    [poc, vah, val] = f_calculate_volume_profile()
    vp_poc_level    := poc
    vp_vah_level    := vah
    vp_val_level    := val
    vp_last_calc_bar := bar_index
    // Reset period bounds for the new structure leg
    vp_period_high  := high
    vp_period_low   := low
    vp_period_start := bar_index
else if use_volume_profile
    // Expand period bounds as price moves
    vp_period_high := math.max(vp_period_high, high)
    vp_period_low  := math.min(vp_period_low,  low)

// =====================================================
// AREA OF INTEREST TRACKING (Phase 2B)
// =====================================================
if use_aoe
    // Push latest bar to front of arrays
    array.unshift(aoe_close_arr, close)
    array.unshift(aoe_open_arr,  open)
    array.unshift(aoe_high_arr,  high)
    array.unshift(aoe_low_arr,   low)
    
    // Trim to lookback length
    if array.size(aoe_close_arr) > aoe_lookback
        array.pop(aoe_close_arr)
        array.pop(aoe_open_arr)
        array.pop(aoe_high_arr)
        array.pop(aoe_low_arr)
    
    // Calculate AOE levels once we have enough data
    if array.size(aoe_close_arr) >= aoe_lookback
        aoe_high := math.max(array.max(aoe_close_arr), array.max(aoe_open_arr))
        aoe_low  := math.min(array.min(aoe_close_arr), array.min(aoe_open_arr))
        
        // Detect breakouts from the consolidation zone
        aoe_breakout_bull := close > aoe_high and close[1] <= aoe_high
        aoe_breakout_bear := close < aoe_low  and close[1] >= aoe_low
        
        // Draw / update AOE box
        if show_aoe_box
            if na(aoe_box)
                aoe_box := box.new(bar_index - aoe_lookback, aoe_high, bar_index, aoe_low,
                                   bgcolor=aoe_box_color,
                                   border_color=color.new(color.purple, 30),
                                   border_width=1,
                                   text="AOE", text_color=color.new(color.purple, 20),
                                   text_size=size.small)
            else
                box.set_lefttop(aoe_box,     bar_index - aoe_lookback, aoe_high)
                box.set_rightbottom(aoe_box, bar_index,                aoe_low)
    else
        aoe_breakout_bull := false
        aoe_breakout_bear := false

// Check if price is inside active zones
in_bu_ob = false
for bull_ob in bu_ob_boxes
    if not na(bull_ob)
        top = box.get_top(bull_ob)
        bot = box.get_bottom(bull_ob)
        if close <= top and close >= bot
            in_bu_ob := true

in_be_ob = false
for bear_ob in be_ob_boxes
    if not na(bear_ob)
        top = box.get_top(bear_ob)
        bot = box.get_bottom(bear_ob)
        if close <= top and close >= bot
            in_be_ob := true

in_bu_fvg = false
for bull_fvg_box in bu_fvg_boxes
    if not na(bull_fvg_box)
        top = box.get_top(bull_fvg_box)
        bot = box.get_bottom(bull_fvg_box)
        if close <= top and close >= bot
            in_bu_fvg := true

in_be_fvg = false
for bear_fvg_box in be_fvg_boxes
    if not na(bear_fvg_box)
        top = box.get_top(bear_fvg_box)
        bot = box.get_bottom(bear_fvg_box)
        if close <= top and close >= bot
            in_be_fvg := true

// Find nearest target zones for visual guidance ("Wait for Zone Touch")
float nearest_bu_zone = na
float nearest_be_zone = na

// Intelligence: Find the highest active Demand zone (OB or FVG) that is BELOW current price
// Priority 1: Order Blocks
for bull_ob in bu_ob_boxes
    if not na(bull_ob)
        top = box.get_top(bull_ob)
        if top < close // Must be below current price to be a valid pullback target
            if na(nearest_bu_zone) or top > nearest_bu_zone
                nearest_bu_zone := top
// Priority 2: FVGs (if no OB found near current price)
if na(nearest_bu_zone)
    for bull_fvg_box in bu_fvg_boxes
        if not na(bull_fvg_box)
            top = box.get_top(bull_fvg_box)
            if top < close
                if na(nearest_bu_zone) or top > nearest_bu_zone
                    nearest_bu_zone := top

// Intelligence: Find the lowest active Supply zone (OB or FVG) that is ABOVE current price
// Priority 1: Order Blocks
for bear_ob in be_ob_boxes
    if not na(bear_ob)
        bot = box.get_bottom(bear_ob)
        if bot > close // Must be above current price to be a valid pullback target
            if na(nearest_be_zone) or bot < nearest_be_zone
                nearest_be_zone := bot
// Priority 2: FVGs (if no OB found near current price)
if na(nearest_be_zone)
    for bear_fvg_box in be_fvg_boxes
        if not na(bear_fvg_box)
            bot = box.get_bottom(bear_fvg_box)
            if bot > close
                if na(nearest_be_zone) or bot < nearest_be_zone
                    nearest_be_zone := bot

// Determine active target zone based on bias
float active_target_zone = htf_bull ? nearest_bu_zone : nearest_be_zone
color target_zone_color = htf_bull ? color.new(color.lime, 40) : color.new(color.red, 40)

// =====================================================
// SUPPORT & RESISTANCE DETECTION (Task 8)
// =====================================================

// Pivot-based support and resistance
ph = ta.pivothigh(high, pivot_len, pivot_len)
pl = ta.pivotlow(low, pivot_len, pivot_len)

if not na(ph)
    last_resistance := ph
if not na(pl)
    last_support := pl

// Check proximity to S/R levels
near_support = f_near(close, last_support, zone_dist)
near_resistance = f_near(close, last_resistance, zone_dist)

// Plot S/R lines
// Plot S/R lines (with anti-compression check)
sr_dist_limit = close * 0.01
plot(show_sr and not na(last_support) and math.abs(close - last_support) < sr_dist_limit ? last_support : na, "Support", color=color.new(color.green, 0), style=plot.style_linebr, linewidth=2)
plot(show_sr and not na(last_resistance) and math.abs(close - last_resistance) < sr_dist_limit ? last_resistance : na, "Resistance", color=color.new(color.red, 0), style=plot.style_linebr, linewidth=2)

// =====================================================
// VOLUME PROFILE VISUAL LINES (Phase 2A)
// =====================================================
// Draw / update POC and VAH/VAL lines on every bar (extend to current bar)
// Draw / update POC and VAH/VAL lines on every bar (with anti-compression logic)
vp_dist_limit = close * 0.01
if use_volume_profile and not na(vp_poc_level)
    is_poc_near = math.abs(close - vp_poc_level) < vp_dist_limit
    if show_poc_line and is_poc_near
        if na(vp_poc_line)
            vp_poc_line := line.new(vp_last_calc_bar, vp_poc_level, bar_index, vp_poc_level,
                                    color=poc_color, width=2, style=line.style_solid)
        else
            line.set_x2(vp_poc_line, bar_index)
            line.set_y1(vp_poc_line, vp_poc_level)
            line.set_y2(vp_poc_line, vp_poc_level)
    else if not na(vp_poc_line)
        line.delete(vp_poc_line)
        vp_poc_line := na
    
    if show_vah_val
        is_vah_near = not na(vp_vah_level) and math.abs(close - vp_vah_level) < vp_dist_limit
        is_val_near = not na(vp_val_level) and math.abs(close - vp_val_level) < vp_dist_limit
        
        if show_vah_val and is_vah_near
            if na(vp_vah_line)
                vp_vah_line := line.new(vp_last_calc_bar, vp_vah_level, bar_index, vp_vah_level,
                                        color=va_color, width=1, style=line.style_dashed)
            else
                line.set_x2(vp_vah_line, bar_index)
                line.set_y1(vp_vah_line, vp_vah_level)
                line.set_y2(vp_vah_line, vp_vah_level)
        else if not na(vp_vah_line)
            line.delete(vp_vah_line)
            vp_vah_line := na
            
        if show_vah_val and is_val_near
            if na(vp_val_line)
                vp_val_line := line.new(vp_last_calc_bar, vp_val_level, bar_index, vp_val_level,
                                        color=va_color, width=1, style=line.style_dashed)
            else
                line.set_x2(vp_val_line, bar_index)
                line.set_y1(vp_val_line, vp_val_level)
                line.set_y2(vp_val_line, vp_val_level)
        else if not na(vp_val_line)
            line.delete(vp_val_line)
            vp_val_line := na

// Derived VP proximity flags (used in scoring below)
near_poc          = f_near_poc(close, vp_poc_level, zone_dist)
inside_value_area = f_inside_value_area(close, vp_vah_level, vp_val_level)
in_discount_va    = use_volume_profile and not na(vp_val_level) and close < vp_val_level
in_premium_va     = use_volume_profile and not na(vp_vah_level) and close > vp_vah_level

// =====================================================
// PREMIUM & DISCOUNT ZONE ANALYSIS (Task 10)
// =====================================================

// Calculate equilibrium midpoint between recent swing high and low
midpoint = (h0 + l0) / 2

// Classify current price zone
premium = close > midpoint
ndiscount = close < midpoint
in_premium = premium
in_discount = ndiscount

// =====================================================
// CONFLUENCE SCORING ENGINE + GOLD TRICKS
// =====================================================

// Range filter — avoid consolidation noise
range_filter = ta.atr(14) > ta.sma(ta.atr(14), 20) * 0.8

// ── FIBONACCI CONFLUENCE (post h0/l0 declaration) ─────
// Gold respects 0.5 and 0.618 retracements with high precision
fib_range   = not na(h0) and not na(l0) ? math.abs(h0 - l0) : atr_val * 5
fib_50_bull = not na(l0) ? l0 + fib_range * 0.50 : na
fib_618_bull = not na(l0) ? l0 + fib_range * 0.618 : na
fib_50_bear = not na(h0) ? h0 - fib_range * 0.50 : na
fib_618_bear = not na(h0) ? h0 - fib_range * 0.618 : na
near_fib_bull = f_near(close, fib_50_bull, zone_dist) or f_near(close, fib_618_bull, zone_dist)
near_fib_bear = f_near(close, fib_50_bear, zone_dist) or f_near(close, fib_618_bear, zone_dist)

// ── BULLISH SCORE ──────────────────────────────────────
buy_score = 0

// Market structure + trend alignment + DXY filter (3 pts)
bull_bias = market == 1 and close > ema_fast and gold_institutional_flow and htf_bull and in_discount and gold_long_allowed
if bull_bias
    buy_score += 3

// Institutional zone entry (2 pts)
if in_bu_ob or in_bu_fvg
    buy_score += 2

// Support proximity (1 pt)
if near_support
    buy_score += 1

// Fibonacci confluence (1 pt) — gold-specific trick
if near_fib_bull
    buy_score += 1

// Liquidity sweep (1 pt)
if liq_low_sweep
    buy_score += 1

// RSI momentum (1 pt)
bull_rsi_ok = rsi_val >= validated_rsi_buy_min and rsi_val < 70
if bull_rsi_ok
    buy_score += 1

// Volume confirmation (1 pt)
if use_volume_filter ? vol_ok : true
    buy_score += 1

// Range filter (1 pt)
if range_filter
    buy_score += 1

// ── BEARISH SCORE ──────────────────────────────────────
sell_score = 0

// Market structure + trend alignment + DXY filter (3 pts)
bear_bias = market == -1 and close < ema_fast and gold_institutional_sell and htf_bear and in_premium and gold_short_allowed
if bear_bias
    sell_score += 3

// Institutional zone entry (2 pts)
if in_be_ob or in_be_fvg
    sell_score += 2

// Resistance proximity (1 pt)
if near_resistance
    sell_score += 1

// Fibonacci confluence (1 pt)
if near_fib_bear
    sell_score += 1

// Liquidity sweep (1 pt)
if liq_high_sweep
    sell_score += 1

// RSI momentum (1 pt)
bear_rsi_ok = rsi_val <= validated_rsi_sell_max and rsi_val > 30
if bear_rsi_ok
    sell_score += 1

// Volume confirmation (1 pt)
if use_volume_filter ? vol_ok : true
    sell_score += 1

// Range filter (1 pt)
if range_filter
    sell_score += 1

// ── GOLD BONUS POINTS ─────────────────────────────────
// Round number magnet (+1)
if near_round_number
    if bull_bias
        buy_score += 1
    if bear_bias
        sell_score += 1

// Century level extra bonus (+1) — $100 levels are strongest
if near_century
    if bull_bias
        buy_score += 1
    if bear_bias
        sell_score += 1

// Timing confluences
buy_score  += prime_session_bonus
buy_score  += silver_bullet_bonus
buy_score  += round_num_bonus

sell_score += prime_session_bonus
sell_score += silver_bullet_bonus
sell_score += round_num_bonus

// SFP bonus (+1)
if sfp_bullish and bull_bias
    buy_score += 1
if sfp_bearish and bear_bias
    sell_score += 1

// Institutional VWAP flow alignment (+1)
if gold_institutional_flow and bull_bias
    buy_score += 1
if gold_institutional_sell and bear_bias
    sell_score += 1

// RSI divergence bonus (+1) — high-accuracy reversal signal
if rsi_bullish_div and bull_bias
    buy_score += 1
if rsi_bearish_div and bear_bias
    sell_score += 1

// Consolidation breakout bonus (+1) — explosive moves
if breakout_up and bull_bias
    buy_score += 1
if breakout_down and bear_bias
    sell_score += 1

// Institutional accumulation/distribution (+1)
if institutional_accumulation and bull_bias
    buy_score += 1
if institutional_distribution and bear_bias
    sell_score += 1

// Gold momentum candle confirmation (+1)
if gold_bull_momentum_candle and bull_bias
    buy_score += 1
if gold_bear_momentum_candle and bear_bias
    sell_score += 1

// ── VOLUME PROFILE POC CONFLUENCE (Phase 2A) ──────────
// POC proximity — strong institutional level (+2)
if near_poc and bull_bias
    buy_score += 2
if near_poc and bear_bias
    sell_score += 2

// Inside Value Area in discount/premium (+1)
if inside_value_area and in_discount
    buy_score += 1
if inside_value_area and in_premium
    sell_score += 1

// Below/above Value Area — deep discount/premium (+1)
if in_discount_va and bull_bias
    buy_score += 1
if in_premium_va and bear_bias
    sell_score += 1

// ── AREA OF INTEREST CONFLUENCE (Phase 2B) ────────────
// AOE breakout — consolidation complete, explosive move expected (+2)
if aoe_breakout_bull and bull_bias
    buy_score += 2
if aoe_breakout_bear and bear_bias
    sell_score += 2

// Inside AOE, positioned for breakout (+1)
inside_aoe = use_aoe and not na(aoe_high) and not na(aoe_low) and close <= aoe_high and close >= aoe_low
if inside_aoe and close > (aoe_high + aoe_low) / 2 and bull_bias
    buy_score += 1
if inside_aoe and close < (aoe_high + aoe_low) / 2 and bear_bias
    sell_score += 1

// ── INTERNAL STRUCTURE CONFLUENCE (Maxwell I-BoS/I-CHoCH) ──
// Internal structure alignment — micro-level entry timing (+2)
if (internal_bull_bos or internal_bull_choch) and bull_bias
    buy_score += 2
if (internal_bear_bos or internal_bear_choch) and bear_bias
    sell_score += 2

// ── K-MEANS SUPERTREND ALIGNMENT (+1) ────────────────
// Price above trailing stop = bullish confirmation
if use_adaptive_atr and not na(km_trailing_stop)
    if km_supertrend_os == 1 and bull_bias
        buy_score += 1
    if km_supertrend_os == 0 and bear_bias
        sell_score += 1

// ── AUTO FIBONACCI PROXIMITY (+1) ─────────────────────
// Price near key fib retracement level = confluence
if show_auto_fibs
    if near_auto_fib_bull and bull_bias
        buy_score += 1
    if near_auto_fib_bear and bear_bias
        sell_score += 1

// ── PERFORMANCE AMA ALIGNMENT (+1) ────────────────────
// Price above/below Performance AMA = trend confirmation
if use_adaptive_atr and show_perf_ama and not na(km_perf_ama)
    if close > km_perf_ama and bull_bias
        buy_score += 1
    if close < km_perf_ama and bear_bias
        sell_score += 1

// MSB (Market Structure Break) bonus (+2) — confirms structural trend change
if new_structure_break and bull_bias and market == 1
    buy_score += 2
if new_structure_break and bear_bias and market == -1
    sell_score += 2

// Maximum possible score: ~33 points (18 base + 6 Phase 2 + 5 Phase 3 + 4 SFP/MSB bonuses)

// =====================================================
// AI PROBABILITY SCORING (Gold-Tuned)
// =====================================================

var float probability_buy  = 50.0
var float probability_sell = 50.0

probability_buy  := 50.0
probability_sell := 50.0

// Trend alignment (+10%)
if close > ema_fast and ema_fast > ema_slow
    probability_buy += 10.0
if close < ema_fast and ema_fast < ema_slow
    probability_sell += 10.0

// MTF confluence (+8%)
if mtf_bullish_confluence
    probability_buy += 8.0
if mtf_bearish_confluence
    probability_sell += 8.0

// Institutional order flow (+7%)
if bullish_order_flow
    probability_buy += 7.0
if bearish_order_flow
    probability_sell += 7.0

// Smart money divergence (+6%)
if bullish_divergence
    probability_buy += 6.0
if bearish_divergence
    probability_sell += 6.0

// RSI divergence — gold-specific (+6%)
if rsi_bullish_div
    probability_buy += 6.0
if rsi_bearish_div
    probability_sell += 6.0

// Advanced candle patterns (+5%)
if bullish_pattern
    probability_buy += 5.0
if bearish_pattern
    probability_sell += 5.0

// Liquidity grab confirmation (+5%)
if liquidity_grab_bullish
    probability_buy += 5.0
if liquidity_grab_bearish
    probability_sell += 5.0

// Consolidation breakout (+5%)
if breakout_up
    probability_buy += 5.0
if breakout_down
    probability_sell += 5.0

// Zone proximity (+4%)
if in_bu_ob or in_bu_fvg
    probability_buy += 4.0
if in_be_ob or in_be_fvg
    probability_sell += 4.0

// Fibonacci confluence (+4%)
if near_fib_bull
    probability_buy += 4.0
if near_fib_bear
    probability_sell += 4.0

// Round number / century level (+3%)
if near_round_number and bull_bias
    probability_buy += 3.0
if near_round_number and bear_bias
    probability_sell += 3.0
if near_century and bull_bias
    probability_buy += 2.0
if near_century and bear_bias
    probability_sell += 2.0

// Silver Bullet timing (+10%)
if is_silver_bullet
    probability_buy  += 10.0
    probability_sell += 10.0

// Prime session (+2%)
if in_prime_session
    probability_buy  += 2.0
    probability_sell += 2.0

// Institutional accumulation/distribution (+3%)
if institutional_accumulation and bull_bias
    probability_buy += 3.0
if institutional_distribution and bear_bias
    probability_sell += 3.0

// Internal structure confirmation (+6%) — Phase 3
if internal_bull_bos or internal_bull_choch
    probability_buy += 6.0
if internal_bear_bos or internal_bear_choch
    probability_sell += 6.0

// K-means SuperTrend alignment (+4%) — Phase 3
if use_adaptive_atr and not na(km_trailing_stop)
    if km_supertrend_os == 1
        probability_buy += 4.0
    else
        probability_sell += 4.0

// Auto Fibonacci proximity (+3%) — Phase 3
if near_auto_fib_bull
    probability_buy += 3.0
if near_auto_fib_bear
    probability_sell += 3.0

// Performance AMA alignment (+3%) — Phase 3
if not na(km_perf_ama)
    if close > km_perf_ama
        probability_buy += 3.0
    else
        probability_sell += 3.0

// SFP (Swing Failure Pattern) — liquidity sweep reversal (+7%)
if sfp_bullish
    probability_buy += 7.0
if sfp_bearish
    probability_sell += 7.0

// MSB (Market Structure Break) — structural trend confirmation (+8%)
if new_structure_break and market == 1
    probability_buy += 8.0
if new_structure_break and market == -1
    probability_sell += 8.0

// Regime adjustment
probability_buy  := probability_buy  * regime_multiplier
probability_sell := probability_sell * regime_multiplier

// DXY alignment (+12%)
if gold_long_allowed
    probability_buy  += 12.0
if gold_short_allowed
    probability_sell += 12.0

// VWAP Overextended reduction (-15%)
if is_overbought_vwap
    probability_buy  -= 15.0
if is_oversold_vwap
    probability_sell -= 15.0

// ── VOLUME PROFILE POC PROBABILITY (Phase 2A) ─────────
// Near POC = institutional magnet (+8%)
if near_poc and bull_bias
    probability_buy  += 8.0
if near_poc and bear_bias
    probability_sell += 8.0

// Inside Value Area at discount/premium (+5%)
if inside_value_area and in_discount
    probability_buy  += 5.0
if inside_value_area and in_premium
    probability_sell += 5.0

// ── AREA OF INTEREST PROBABILITY (Phase 2B) ───────────
// AOE breakout = high-conviction institutional move (+7%)
if aoe_breakout_bull
    probability_buy  += 7.0
if aoe_breakout_bear
    probability_sell += 7.0

// Cap at 95%
probability_buy  := math.max(10.0, math.min(probability_buy,  95.0))
probability_sell := math.max(10.0, math.min(probability_sell, 95.0))

// =====================================================
// ADVANCED SIGNAL QUALITY FILTERS
// =====================================================


// Strong trend confirmation
strong_bullish_trend = close > ema_fast and ema_fast > ema_slow and close > vwap_val and htf_bull and in_discount
strong_bearish_trend = close < ema_fast and ema_fast < ema_slow and close < vwap_val and htf_bear and in_premium

// Volume spike
vol_spike   = volume > vol_sma * 1.5
strong_volume = vol_spike or not require_volume_spike

// Zone entry
in_bullish_zone = in_bu_ob or in_bu_fvg or near_support or near_fib_bull
in_bearish_zone = in_be_ob or in_be_fvg or near_resistance or near_fib_bear
valid_zone_entry = (in_bullish_zone and bull_bias) or (in_bearish_zone and bear_bias)

// Momentum
strong_bull_momentum = rsi_val >= 52 and rsi_val < 75
strong_bear_momentum = rsi_val <= 48 and rsi_val > 25

// Strong directional candle
bullish_candle = gold_bull_momentum_candle
bearish_candle = gold_bear_momentum_candle

// ── GOLD TRICK: CONFLUENCE GATE ───────────────────────
// At least 1 gold-specific condition must be true for a signal
gold_bull_conditions = (near_round_number ? 1 : 0) + (near_fib_bull ? 1 : 0) + (rsi_bullish_div ? 1 : 0) + (liquidity_grab_bullish ? 1 : 0) + (breakout_up ? 1 : 0) + (institutional_accumulation ? 1 : 0) + (in_prime_session ? 1 : 0)
gold_bear_conditions = (near_round_number ? 1 : 0) + (near_fib_bear ? 1 : 0) + (rsi_bearish_div ? 1 : 0) + (liquidity_grab_bearish ? 1 : 0) + (breakout_down ? 1 : 0) + (institutional_distribution ? 1 : 0) + (in_prime_session ? 1 : 0)
gold_gate_buy  = gold_bull_conditions >= 1
gold_gate_sell = gold_bear_conditions >= 1

// BEGINNER BUY CONFIRMATION (All must be true)
beginner_buy_confirmed = true
if use_beginner_mode
    // Layer 1: High quality score
    beginner_buy_confirmed := buy_score >= min_quality_score
    
    // Layer 2: Strong trend alignment (if required)
    if require_trend_alignment
        beginner_buy_confirmed := beginner_buy_confirmed and strong_bullish_trend
    
    // Layer 3: Zone entry (if required)
    if require_zone_entry
        beginner_buy_confirmed := beginner_buy_confirmed and in_bullish_zone
    
    // Layer 4: Trending market (if required)
    if block_ranging_market
        beginner_buy_confirmed := beginner_buy_confirmed and trending_market
    
    // Layer 5: Volume spike (if required)
    if require_volume_spike
        beginner_buy_confirmed := beginner_buy_confirmed and vol_spike
    
    // Layer 6: Strong momentum
    beginner_buy_confirmed := beginner_buy_confirmed and strong_bull_momentum
    
    // Layer 7: Strong candle pattern
    beginner_buy_confirmed := beginner_buy_confirmed and bullish_candle
    
    // Layer 8: Gold filters
    beginner_buy_confirmed := beginner_buy_confirmed and gold_conditions_ok

// BEGINNER SELL CONFIRMATION (All must be true)
beginner_sell_confirmed = true
if use_beginner_mode
    // Layer 1: High quality score
    beginner_sell_confirmed := sell_score >= min_quality_score
    
    // Layer 2: Strong trend alignment (if required)
    if require_trend_alignment
        beginner_sell_confirmed := beginner_sell_confirmed and strong_bearish_trend
    
    // Layer 3: Zone entry (if required)
    if require_zone_entry
        beginner_sell_confirmed := beginner_sell_confirmed and in_bearish_zone
    
    // Layer 4: Trending market (if required)
    if block_ranging_market
        beginner_sell_confirmed := beginner_sell_confirmed and trending_market
    
    // Layer 5: Volume spike (if required)
    if require_volume_spike
        beginner_sell_confirmed := beginner_sell_confirmed and vol_spike
    
    // Layer 6: Strong momentum
    beginner_sell_confirmed := beginner_sell_confirmed and strong_bear_momentum
    
    // Layer 7: Strong candle pattern
    beginner_sell_confirmed := beginner_sell_confirmed and bearish_candle
    
    // Layer 8: Gold filters
    beginner_sell_confirmed := beginner_sell_confirmed and gold_conditions_ok

// =====================================================
// SIGNAL GENERATION ENGINE (3-Tier: Scalp / Intraday / Swing)
// =====================================================

// ── NORMAL MODE ────────────────────────────────────────
scalp_buy_normal  = buy_score  >= validated_score_scalp and in_session and gold_conditions_ok and (bull_bias or in_bu_ob or in_bu_fvg or near_support or near_fib_bull or new_structure_break or sfp_bullish)
scalp_sell_normal = sell_score >= validated_score_scalp and in_session and gold_conditions_ok and (bear_bias or in_be_ob or in_be_fvg or near_resistance or near_fib_bear or new_structure_break or sfp_bearish)
intraday_buy_normal  = buy_score  >= validated_score_intraday and in_session and gold_conditions_ok and (bull_bias or in_bu_ob or in_bu_fvg or near_support or near_fib_bull or new_structure_break or sfp_bullish) and htf_bull
intraday_sell_normal = sell_score >= validated_score_intraday and in_session and gold_conditions_ok and (bear_bias or in_be_ob or in_be_fvg or near_resistance or near_fib_bear or new_structure_break or sfp_bearish) and htf_bear
swing_buy_normal  = buy_score  >= validated_score_swing and in_session and gold_conditions_ok and (bull_bias or in_bu_ob or in_bu_fvg or near_support or near_fib_bull or new_structure_break) and htf_bull and mtf_bullish_confluence
swing_sell_normal = sell_score >= validated_score_swing and in_session and gold_conditions_ok and (bear_bias or in_be_ob or in_be_fvg or near_resistance or near_fib_bear or new_structure_break) and htf_bear and mtf_bearish_confluence

// ── BEGINNER MODE ──────────────────────────────────────
scalp_buy_beginner  = beginner_buy_confirmed  and in_session
scalp_sell_beginner = beginner_sell_confirmed and in_session
swing_buy_beginner  = beginner_buy_confirmed  and in_session
swing_sell_beginner = beginner_sell_confirmed and in_session

// ── PROFESSIONAL MODE (Gold-Tuned) ────────────────────
// Requires probability threshold + at least 1 gold-specific condition
scalp_buy_professional  = buy_score  >= (validated_score_scalp - 1) and in_session and gold_conditions_ok and probability_buy  >= min_probability and gold_gate_buy  and (bull_bias or in_bu_ob or in_bu_fvg or near_fib_bull or bullish_divergence or bullish_pattern or liquidity_grab_bullish or breakout_up or sfp_bullish)
scalp_sell_professional = sell_score >= (validated_score_scalp - 1) and in_session and gold_conditions_ok and probability_sell >= min_probability and gold_gate_sell and (bear_bias or in_be_ob or in_be_fvg or near_fib_bear or bearish_divergence or bearish_pattern or liquidity_grab_bearish or breakout_down or sfp_bearish)
intraday_buy_professional  = buy_score  >= (validated_score_intraday - 1) and in_session and gold_conditions_ok and probability_buy  >= min_probability and gold_gate_buy and htf_bull and (bull_bias or in_bu_ob or bullish_divergence or bullish_pattern or sfp_bullish or new_structure_break)
intraday_sell_professional = sell_score >= (validated_score_intraday - 1) and in_session and gold_conditions_ok and probability_sell >= min_probability and gold_gate_sell and htf_bear and (bear_bias or in_be_ob or bearish_divergence or bearish_pattern or sfp_bearish or new_structure_break)
swing_buy_professional  = buy_score  >= (validated_score_swing - 1) and in_session and gold_conditions_ok and probability_buy  >= min_probability and mtf_bullish_confluence and gold_gate_buy  and (bull_bias or in_bu_ob or bullish_divergence or bullish_order_flow or breakout_up)
swing_sell_professional = sell_score >= (validated_score_swing - 1) and in_session and gold_conditions_ok and probability_sell >= min_probability and mtf_bearish_confluence and gold_gate_sell and (bear_bias or in_be_ob or bearish_divergence or bearish_order_flow or breakout_down)

// ── RAW SIGNALS (before cooldown) ─────────────────────
raw_buy  = use_beginner_mode ? beginner_buy_confirmed  : (use_probability_scoring ? (scalp_buy_professional or intraday_buy_professional or swing_buy_professional) : (scalp_buy_normal or intraday_buy_normal or swing_buy_normal))
raw_sell = use_beginner_mode ? beginner_sell_confirmed : (use_probability_scoring ? (scalp_sell_professional or intraday_sell_professional or swing_sell_professional) : (scalp_sell_normal or intraday_sell_normal or swing_sell_normal))
raw_swing_buy  = use_beginner_mode ? beginner_buy_confirmed  : (use_probability_scoring ? swing_buy_professional  : swing_buy_normal)
raw_swing_sell = use_beginner_mode ? beginner_sell_confirmed : (use_probability_scoring ? swing_sell_professional : swing_sell_normal)
raw_intraday_buy  = use_beginner_mode ? beginner_buy_confirmed  : (use_probability_scoring ? intraday_buy_professional  : intraday_buy_normal)
raw_intraday_sell = use_beginner_mode ? beginner_sell_confirmed : (use_probability_scoring ? intraday_sell_professional : intraday_sell_normal)

// ── CONFLICT FILTER: no simultaneous BUY + SELL ───────
// When both fire, keep only the higher-score one
conflict = raw_buy and raw_sell
buy_wins  = conflict and buy_score  >= sell_score
sell_wins = conflict and sell_score >  buy_score
filtered_buy  = raw_buy  and (not conflict or buy_wins)
filtered_sell = raw_sell and (not conflict or sell_wins)

// ── COOLDOWN FILTER: prevent signal clusters ──────────
// A new buy is only valid if enough bars have passed since last buy
// AND it's not the same direction as the immediately preceding signal
buy_cooldown_ok  = (bar_index - last_buy_bar)  >= signal_cooldown
sell_cooldown_ok = (bar_index - last_sell_bar) >= signal_cooldown

// Additional: don't flip direction too fast (anti-whipsaw)
// Must wait at least half the cooldown before switching direction
flip_ok_to_buy  = not last_signal_was_buy  or (bar_index - last_buy_bar)  >= signal_cooldown
flip_ok_to_sell = last_signal_was_buy      or (bar_index - last_sell_bar) >= signal_cooldown

// Score gate: only show labels for meaningful signals
score_ok_buy  = buy_score  >= min_score_to_show
score_ok_sell = sell_score >= min_score_to_show

// Final gated signals (3-tier)
scalp_buy  = filtered_buy  and buy_cooldown_ok  and flip_ok_to_buy  and score_ok_buy  and in_session and not raw_intraday_buy and not raw_swing_buy
scalp_sell = filtered_sell and sell_cooldown_ok and flip_ok_to_sell and score_ok_sell and in_session and not raw_intraday_sell and not raw_swing_sell
intraday_buy  = raw_intraday_buy  and buy_cooldown_ok  and flip_ok_to_buy  and score_ok_buy  and in_session and not raw_swing_buy
intraday_sell = raw_intraday_sell and sell_cooldown_ok and flip_ok_to_sell and score_ok_sell and in_session and not raw_swing_sell
swing_buy  = raw_swing_buy  and buy_cooldown_ok  and flip_ok_to_buy  and score_ok_buy  and in_session
swing_sell = raw_swing_sell and sell_cooldown_ok and flip_ok_to_sell and score_ok_sell and in_session

strong_buy  = show_signals and (scalp_buy or intraday_buy or swing_buy)
strong_sell = show_signals and (scalp_sell or intraday_sell or swing_sell)

// Update cooldown trackers
if strong_buy
    last_buy_bar := bar_index
    last_signal_was_buy := true
if strong_sell
    last_sell_bar := bar_index
    last_signal_was_buy := false

// ── SIGNAL TYPE PERSISTENCE (Memory Logic) ────────────
var string persistent_signal_type = "No Signal"
var color persistent_signal_color = color.gray
var int last_signal_bar_any = 0
var int active_signal_dir = 0 // 1=buy, -1=sell
var float active_signal_prob = 0.0
var int active_signal_score = 0
var bool trade_lockdown = false

// --- INSTITUTIONAL PARTICIPATION (Volatility Surge) ---
vol_participation = volume > ta.sma(volume, 20) * 1.2
mkt_watch_ok = gold_conditions_ok and in_session and vol_participation

// --- NOISE FILTERING ---
bool in_any_zone = in_bu_ob or in_be_ob or in_bu_fvg or in_be_fvg
int required_score = in_any_zone ? 5 : 6 // Higher score needed in Neutral Zones

// --- HTF ALIGNMENT HARDENING ---
bool buy_aligned = htf_bull ? buy_score >= required_score : buy_score >= 7 // Counter-trend needs 7/8
bool sell_aligned = not htf_bull ? sell_score >= required_score : sell_score >= 7

var float frozen_ep  = 0.0
var float frozen_sl  = 0.0
var float frozen_tp1 = 0.0
var float frozen_tp2 = 0.0
var float frozen_risk = 0.0

// =====================================================
// DYNAMIC SL/TP CALCULATION (Gated by Signal State)
// =====================================================

// Stop-loss calculation for buy signals
long_base_sl = na(l0) ? close - atr_val : math.min(l0, close - atr_val * 1.1)
buy_sl = use_adaptive_atr ? long_base_sl - atr_val * (current_adaptive_factor * 0.1) : long_base_sl - atr_val * 0.15

// Stop-loss calculation for sell signals
short_base_sl = na(h0) ? close + atr_val : math.max(h0, close + atr_val * 1.1)
sell_sl = use_adaptive_atr ? short_base_sl + atr_val * (current_adaptive_factor * 0.1) : short_base_sl + atr_val * 0.15

// Risk calculation
buy_entry = close
sell_entry = close
buy_risk = buy_entry - buy_sl
sell_risk = sell_sl - sell_entry

// Determine RR ratio based on signal type (3-tier)
buy_r = swing_buy ? rr_swing : intraday_buy ? rr_intraday : rr_scalp
sell_r = swing_sell ? rr_swing : intraday_sell ? rr_intraday : rr_scalp

// Take-profit calculation for buy signals
buy_tp1 = buy_entry + buy_risk * buy_r
buy_tp2 = buy_entry + buy_risk * (buy_r + 1.0)
buy_tp3 = buy_entry + buy_risk * (buy_r + 1.5)

// Take-profit calculation for sell signals
sell_tp1 = sell_entry - sell_risk * sell_r
sell_tp2 = sell_entry - sell_risk * (sell_r + 1.0)
sell_tp3 = sell_entry - sell_risk * (sell_r + 1.5)

if strong_buy and not trade_lockdown and buy_aligned and mkt_watch_ok
    persistent_signal_type := swing_buy ? "⚡ SWING BUY" : intraday_buy ? "📊 INTRADAY BUY" : "🔥 SCALP BUY"
    persistent_signal_color := swing_buy ? color.aqua : intraday_buy ? color.lime : color.yellow
    last_signal_bar_any := bar_index
    active_signal_dir := 1
    active_signal_prob := probability_buy
    active_signal_score := buy_score
    trade_lockdown := true
    // Freeze Entry, SL, and TP to prevent fluctuations
    frozen_ep  := buy_entry
    frozen_sl  := buy_sl
    frozen_tp1 := buy_tp1
    frozen_tp2 := buy_tp2
    frozen_risk := math.abs(buy_entry - buy_sl)
else if strong_sell and not trade_lockdown and sell_aligned and mkt_watch_ok
    persistent_signal_type := swing_sell ? "⚡ SWING SELL" : intraday_sell ? "📊 INTRADAY SELL" : "🔥 SCALP SELL"
    persistent_signal_color := swing_sell ? color.aqua : intraday_sell ? color.lime : color.red
    last_signal_bar_any := bar_index
    active_signal_dir := -1
    active_signal_prob := probability_sell
    active_signal_score := sell_score
    trade_lockdown := true
    // Freeze Entry, SL, and TP to prevent fluctuations
    frozen_ep  := sell_entry
    frozen_sl  := sell_sl
    frozen_tp1 := sell_tp1
    frozen_tp2 := sell_tp2
    frozen_risk := math.abs(sell_sl - sell_entry)

// --- REVERSAL IMMINENT DETECTION (Pre-Alerts) ---
// Refined Accuracy: Check for Zone Entry + RSI Extreme + Momentum Stalling
bool is_stalling_up = high >= high[1] and close < open
bool is_stalling_dn = low <= low[1] and close > open
bool vol_climax = volume > ta.sma(volume, 20) * 1.5

bool is_reversal_imminent_bear = (in_be_ob or in_be_fvg) and rsi_val > 68 and is_stalling_up and vol_climax
bool is_reversal_imminent_bull = (in_bu_ob or in_bu_fvg) and rsi_val < 32 and is_stalling_dn and vol_climax

// --- CHART TAGS: Early Exit / Reversal Warning ---
if is_reversal_imminent_bear
    label.new(bar_index, high, "🛑 EXIT NOW\nBearish Reversal", style=label.style_label_down, color=color.new(color.red, 20), textcolor=color.white, size=size.small)
if is_reversal_imminent_bull
    label.new(bar_index, low, "🟢 EXIT NOW\nBullish Reversal", style=label.style_label_up, color=color.new(color.lime, 20), textcolor=color.black, size=size.small)

// Clear persistence after 20 bars to avoid stale data
signal_recent = (bar_index - last_signal_bar_any) <= 20
if not signal_recent
    persistent_signal_type := "No Signal"
    persistent_signal_color := color.gray
    active_signal_dir := 0
    active_signal_prob := 0.0
    active_signal_score := 0

// =====================================================
// SNIPER ENTRY LOGIC (Task 13.3 & 13.4)
// =====================================================

// Get last order block levels
get_last_box_top(arr) => array.size(arr) > 0 ? box.get_top(array.get(arr, array.size(arr)-1)) : na
get_last_box_bot(arr) => array.size(arr) > 0 ? box.get_bottom(array.get(arr, array.size(arr)-1)) : na

be_top = get_last_box_top(be_ob_boxes)
be_bot = get_last_box_bot(be_ob_boxes)
bu_top = get_last_box_top(bu_ob_boxes)
bu_bot = get_last_box_bot(bu_ob_boxes)

// Breakout conditions
break_above_supply = not na(be_top) and close > be_top and close[1] <= be_top
follow_through_up = break_above_supply and close > open and close > high[1]

break_below_demand = not na(bu_bot) and close < bu_bot and close[1] >= bu_bot
follow_through_dn = break_below_demand and close < open and close < low[1]

// Rejection conditions
rejection_supply = not na(be_top) and high > be_top and close < be_top
rejection_demand = not na(bu_bot) and low < bu_bot and close > bu_bot

// Strong body filters
strong_body_up = close > open and (close - open) > (high - low) * 0.5
strong_body_dn = close < open and (open - close) > (high - low) * 0.5

// Sniper entry conditions
valid_breakout_buy = follow_through_up and strong_body_up and htf_bull and in_session
valid_breakout_sell = follow_through_dn and strong_body_dn and htf_bear and in_session

valid_rejection_sell = rejection_supply and bear_bias and in_session
valid_rejection_buy = rejection_demand and bull_bias and in_session

// Sniper signals - Allow without requiring structure break
sniper_buy = (valid_breakout_buy or valid_rejection_buy) and in_session
sniper_sell = (valid_breakout_sell or valid_rejection_sell) and in_session

// Take-profit calculation for sell signals
// (Targets already calculated above for logic flow)

// Sniper SL/TP (reuse dynamic calculations)
sn_buy_sl = buy_sl
sn_buy_tp = buy_tp1
sn_sell_sl = sell_sl
sn_sell_tp = sell_tp1

// --- TARGET TRACKING FOR LOCKDOWN (Institutional Resilience) ---
if trade_lockdown
    bool hit_sl = (active_signal_dir == 1 and low <= frozen_sl) or (active_signal_dir == -1 and high >= frozen_sl)
    bool hit_tp = (active_signal_dir == 1 and high >= frozen_tp1) or (active_signal_dir == -1 and low <= frozen_tp1)
    if hit_sl or hit_tp or bar_index - last_signal_bar_any > 30 // Max 30 bars lockdown
        trade_lockdown := false

// --- INSTITUTIONAL STATE INVALIDATION (Emergency Exit) ---
// If the core thesis is invalidated by score or HTF bias, kill the trade
bool invalid_buy = trade_lockdown and active_signal_dir == 1 and (not htf_bull or buy_score < 4)
bool invalid_sell = trade_lockdown and active_signal_dir == -1 and (htf_bull or sell_score < 4)

if invalid_buy or invalid_sell or manual_reset
    trade_lockdown := false
    persistent_signal_type := manual_reset ? "No Signal" : "INVALIDATED ❌"
    persistent_signal_color := color.gray
    active_signal_dir := 0
    active_signal_prob := 0.0
    active_signal_score := 0
    frozen_ep := 0.0
    frozen_sl := 0.0
    frozen_tp1 := 0.0
    frozen_tp2 := 0.0
    frozen_risk := 0.0
    if manual_reset
        last_signal_bar_any := bar_index - 50 // Force signal_recent to false

// =====================================================
// VISUAL SIGNAL DISPLAY (Clean, Non-Overlapping)
// =====================================================

// Build compact reason tag (max 3 reasons to keep label small)
f_buy_reason() =>
    r = ""
    count = 0
    if liquidity_grab_bullish and count < 3
        r := r + "LiqGrab "
        count := count + 1
    if rsi_bullish_div and count < 3
        r := r + "RSIDiv "
        count := count + 1
    if near_poc and count < 3
        r := r + "POC "
        count := count + 1
    if aoe_breakout_bull and count < 3
        r := r + "AOE-BRK "
        count := count + 1
    if near_fib_bull and count < 3
        r := r + "Fib "
        count := count + 1
    if near_round_number and count < 3
        r := r + "RndNum "
        count := count + 1
    if breakout_up and count < 3
        r := r + "Breakout "
        count := count + 1
    if bullish_pattern and count < 3
        r := r + "Pattern "
        count := count + 1
    if in_bu_ob and count < 3
        r := r + "OB"
        count := count + 1
    r

f_sell_reason() =>
    r = ""
    count = 0
    if liquidity_grab_bearish and count < 3
        r := r + "LiqGrab "
        count := count + 1
    if rsi_bearish_div and count < 3
        r := r + "RSIDiv "
        count := count + 1
    if near_poc and count < 3
        r := r + "POC "
        count := count + 1
    if aoe_breakout_bear and count < 3
        r := r + "AOE-BRK "
        count := count + 1
    if near_fib_bear and count < 3
        r := r + "Fib "
        count := count + 1
    if near_round_number and count < 3
        r := r + "RndNum "
        count := count + 1
    if breakout_down and count < 3
        r := r + "Breakout "
        count := count + 1
    if bearish_pattern and count < 3
        r := r + "Pattern "
        count := count + 1
    if in_be_ob and count < 3
        r := r + "OB"
        count := count + 1
    r

// ── BUY SIGNAL LABEL ──────────────────────────────────
if strong_buy
    _type = swing_buy ? "SWING" : intraday_buy ? "INTRADAY" : "SCALP"
    _prob = use_probability_scoring ? " " + str.tostring(math.round(probability_buy)) + "%" : ""
    _ep   = str.tostring(buy_entry, format.mintick)
    _sl   = str.tostring(buy_sl,   format.mintick)
    _tp1  = str.tostring(buy_tp1,  format.mintick)
    _tp2  = str.tostring(buy_tp2,  format.mintick)
    _why  = f_buy_reason()
    label.new(bar_index, low,
         "▲ BUY " + _type + _prob +
         "\nEP " + _ep +
         "\nSL " + _sl + "  TP1 " + _tp1 +
         "\nTP2 " + _tp2 +
         "\n" + _why,
         style=label.style_label_up,
         color=color.new(color.green, 10),
         textcolor=color.white,
         size=size.small)

// ── SELL SIGNAL LABEL ─────────────────────────────────
if strong_sell
    _type = swing_sell ? "SWING" : intraday_sell ? "INTRADAY" : "SCALP"
    _prob = use_probability_scoring ? " " + str.tostring(math.round(probability_sell)) + "%" : ""
    _ep   = str.tostring(sell_entry, format.mintick)
    _sl   = str.tostring(sell_sl,  format.mintick)
    _tp1  = str.tostring(sell_tp1, format.mintick)
    _tp2  = str.tostring(sell_tp2, format.mintick)
    _why  = f_sell_reason()
    label.new(bar_index, high,
         "▼ SELL " + _type + _prob +
         "\nEP " + _ep +
         "\nSL " + _sl + "  TP1 " + _tp1 +
         "\nTP2 " + _tp2 +
         "\n" + _why,
         style=label.style_label_down,
         color=color.new(color.red, 10),
         textcolor=color.white,
         size=size.small)

// ── SNIPER LABELS (compact) ───────────────────────────
if sniper_buy and buy_cooldown_ok
    label.new(bar_index, low,
         "⚡BUY\n" + (valid_breakout_buy ? "BRK" : "REJ") +
         "\nSL " + str.tostring(sn_buy_sl, format.mintick),
         style=label.style_label_up,
         color=color.new(color.teal, 20),
         textcolor=color.white,
         size=size.tiny)

if sniper_sell and sell_cooldown_ok
    label.new(bar_index, high,
         "⚡SELL\n" + (valid_breakout_sell ? "BRK" : "REJ") +
         "\nSL " + str.tostring(sn_sell_sl, format.mintick),
         style=label.style_label_down,
         color=color.new(color.orange, 20),
         textcolor=color.white,
         size=size.tiny)

// ── SHAPE MARKERS (small, clean) ─────────────────────
plotshape(strong_buy,  title="Buy Signal",  location=location.belowbar, style=shape.triangleup,   size=size.small, color=color.new(color.lime,  0))
plotshape(strong_sell, title="Sell Signal", location=location.abovebar, style=shape.triangledown, size=size.small, color=color.new(color.red,   0))

// ── SILVER BULLET LABEL (START MARKER ONLY) ──────────
plotshape(is_silver_bullet and not is_silver_bullet[1], "Silver Bullet Window Start", shape.flag, location.top, color.new(color.yellow, 0), text="SB", textcolor=color.black, size=size.tiny)

// ── PDH/PDL PLOTS (with anti-compression check) ───────
pd_dist_limit = close * 0.01
plot(show_pdh_pdl and not na(pdh) and math.abs(close - pdh) < pd_dist_limit ? pdh : na, "PDH", color=color.new(color.gray, 50), style=plot.style_stepline)
plot(show_pdh_pdl and not na(pdl) and math.abs(close - pdl) < pd_dist_limit ? pdl : na, "PDL", color=color.new(color.gray, 50), style=plot.style_stepline)

// ── TARGET ENTRY ZONE PLOT ("Wait for Zone Touch" visual) ──
// Filter: Only plot if zone is within 1.5% of current price to prevent vertical compression
float zone_dist_pct = math.abs(close - active_target_zone) / close * 100
bool is_zone_near = zone_dist_pct < 1.5 // 1.5% proximity limit (Target zone can be slightly further than indicator lines)

// EMA plots (with proximity check to avoid compression)
ema_dist_limit = close * 0.01
plot(show_ema and math.abs(close - ema_fast) < ema_dist_limit ? ema_fast : na, "EMA Fast", color=color.new(color.yellow, 0), linewidth=2)
plot(show_ema and math.abs(close - ema_slow) < ema_dist_limit ? ema_slow : na, "EMA Slow", color=color.new(color.orange, 15), linewidth=2)

// VWAP plots (with proximity check to avoid compression)
vwap_dist_limit = close * 0.01
plot(show_vwap and math.abs(close - vwap_val) < vwap_dist_limit ? vwap_val : na, "VWAP", color=color.new(color.aqua, 0), linewidth=2)
plot(show_vwap and math.abs(close - vwap_upper_2) < vwap_dist_limit ? vwap_upper_2 : na, "VWAP Upper 2SD", color=color.new(color.red, 60), style=plot.style_linebr)
plot(show_vwap and math.abs(close - vwap_lower_2) < vwap_dist_limit ? vwap_lower_2 : na, "VWAP Lower 2SD", color=color.new(color.green, 60), style=plot.style_linebr)

plot(show_target_zone and not strong_buy and not strong_sell and is_zone_near ? active_target_zone : na, "Target Entry Zone", color=target_zone_color, style=plot.style_linebr, linewidth=3)
is_wait_zone_visible = show_target_zone and not strong_buy and not strong_sell and is_zone_near and (math.abs(close - active_target_zone) / close < 0.005)
plotshape(is_wait_zone_visible ? active_target_zone : na, "Target Zone Marker", shape.labeldown, location.absolute, target_zone_color, text="WAIT ZONE", textcolor=color.white, size=size.tiny)

// ── SFP & EQL/EQH LABELS (CONFLUENCE FILTERED) ───────
// Only show minor patterns if they occur in high-probability areas to reduce clutter
show_minor_labels = (is_silver_bullet or in_bu_ob or in_be_ob or in_bu_fvg or in_be_fvg or buy_score >= 4 or sell_score >= 4)

plotshape(sfp_bullish and show_minor_labels, "SFP Bullish", shape.labelup, location.belowbar, color.new(color.green, 0), text="SFP", textcolor=color.white, size=size.tiny)
plotshape(sfp_bearish and show_minor_labels, "SFP Bearish", shape.labeldown, location.abovebar, color.new(color.red, 0), text="SFP", textcolor=color.white, size=size.tiny)

plotshape(is_eql and show_minor_labels, "Equal Lows (Liq)", shape.diamond, location.belowbar, color.new(color.white, 50), text="EQL", textcolor=color.white, size=size.tiny)
plotshape(is_eqh and show_minor_labels, "Equal Highs (Liq)", shape.diamond, location.abovebar, color.new(color.white, 50), text="EQH", textcolor=color.white, size=size.tiny)

// ── DATA WINDOW DEBUG ─────────────────────────────────
plot(buy_score,  "Buy Score",  color=color.new(color.green, 70), display=display.data_window)
plot(sell_score, "Sell Score", color=color.new(color.red,   70), display=display.data_window)
plot(probability_buy,  "Prob Buy",  color=color.new(color.green, 70), display=display.data_window)
plot(probability_sell, "Prob Sell", color=color.new(color.red,   70), display=display.data_window)

// redundant indicator lines removed (now handled at line 2521 with proximity checks)

// =====================================================
// LIVE INSTITUTIONAL INTELLIGENCE DASHBOARD
// =====================================================
var table dashboard = table.new(position.bottom_right, 2, 24, bgcolor=color.new(color.black, 5), border_width=1, border_color=color.new(color.gray, 30))

if barstate.islast
    // ── ROW 0: Header ────────────────────────────────────
    table.cell(dashboard, 0, 0, "MINDSCAPE ANALYTICS PRO+", text_color=color.white, text_size=size.small, bgcolor=color.new(color.gray, 10))
    table.merge_cells(dashboard, 0, 0, 1, 0)
    
    // ── ROW 1: HTF Bias ──────────────────────────────────
    bias_text = htf_bull ? "BULLISH ▲" : "BEARISH ▼"
    // Accuracy: Show warning if bias is against current trade
    bias_display = (active_signal_dir == -1 and htf_bull) or (active_signal_dir == 1 and not htf_bull) ? bias_text + " ⚠️" : bias_text
    bias_color = htf_bull ? color.green : color.red
    table.cell(dashboard, 0, 1, "HTF Bias", text_color=color.white, text_size=size.small)
    table.cell(dashboard, 1, 1, bias_display, text_color=bias_color, text_size=size.small)
    
    // ── ROW 2: Current Zone ──────────────────────────────
    zone_text = in_bu_ob ? "Inside Demand OB" : in_be_ob ? "Inside Supply OB" : in_bu_fvg ? "In Bull-FVG" : in_be_fvg ? "In Bear-FVG" : "Neutral Zone"
    
    // Accuracy: Is this zone helping or hurting our trade?
    string zone_display = zone_text
    if active_signal_dir == 1 and (in_be_ob or in_be_fvg)
        zone_display := zone_text + " 🛑" // Buying into supply
    else if active_signal_dir == -1 and (in_bu_ob or in_bu_fvg)
        zone_display := zone_text + " 🛑" // Selling into demand
        
    zone_color = (in_bu_ob or in_bu_fvg) ? color.green : (in_be_ob or in_be_fvg) ? color.red : color.white
    table.cell(dashboard, 0, 2, "Current Zone", text_color=color.white, text_size=size.small)
    table.cell(dashboard, 1, 2, zone_display, text_color=zone_color, text_size=size.small)
    
    // ── ROW 3: Buy/Sell Score ────────────────────────────
    string score_text = ""
    if persistent_signal_type == "INVALIDATED ❌"
        score_text := "Score: N/A (VOIDED)"
    else if active_signal_dir == 1
        score_text := "BUY Score: " + str.tostring(buy_score) + "/8"
    else if active_signal_dir == -1
        score_text := "SELL Score: " + str.tostring(sell_score) + "/8"
    else
        score_text := str.tostring(buy_score) + "B / " + str.tostring(sell_score) + "S"
        
    score_color = persistent_signal_type == "INVALIDATED ❌" ? color.gray : buy_score > sell_score ? color.lime : sell_score > buy_score ? color.red : color.yellow
    table.cell(dashboard, 0, 3, "Buy/Sell Score", text_color=color.white, text_size=size.small)
    table.cell(dashboard, 1, 3, score_text, text_color=score_color, text_size=size.small)
    
    // ── ROW 4: Market Timing ─────────────────────────────
    timing_text = is_silver_bullet ? "SILVER BULLET 🎯" : in_prime_session ? "Prime Session" : "Asian Session 💤"
    timing_color = is_silver_bullet ? color.yellow : in_prime_session ? color.aqua : color.gray
    table.cell(dashboard, 0, 4, "Market Timing", text_color=color.white, text_size=size.small)
    table.cell(dashboard, 1, 4, timing_text, text_color=timing_color, text_size=size.small)
    
    // ── ROW 5: Dollar Correlation ────────────────────────
    string dxy_label = dxy_bullish ? "DXY BULLISH" : "DXY BEARISH"
    string dxy_status = ""
    color dxy_color = dxy_bullish ? color.red : color.lime
    
    // Accuracy: Is DXY supporting or opposing our trade?
    if active_signal_dir == 1 // Buy
        dxy_status := dxy_bullish ? " ❌ Oppose" : " ✅ Align"
    else if active_signal_dir == -1 // Sell
        dxy_status := dxy_bullish ? " ✅ Align" : " ❌ Oppose"
    else
        dxy_status := dxy_bullish ? " ⚠️ Risk" : " ✅ Healthy"
        
    table.cell(dashboard, 0, 5, "Dollar (DXY)", text_color=color.white, text_size=size.small)
    table.cell(dashboard, 1, 5, dxy_label + dxy_status, text_color=dxy_color, text_size=size.small)
    
    // ── ROW 6: Key Context ───────────────────────────────
    conf_text = near_round_num ? "Round Num 🔥" : trending_market ? "Trend Flow" : "Range/Hedge"
    conf_color = near_round_num ? color.orange : color.white
    table.cell(dashboard, 0, 6, "Key Context", text_color=color.white, text_size=size.small)
    table.cell(dashboard, 1, 6, conf_text, text_color=conf_color, text_size=size.small)
    
    // ── ROW 7: Internal Structure ────────────────────────
    int_stru_text = internal_bull_choch ? "Bull I-CHoCH 🔄" : internal_bear_choch ? "Bear I-CHoCH 🔄" : internal_bull_bos ? "Bull I-BoS ▲" : internal_bear_bos ? "Bear I-BoS ▼" : "No Signal"
    int_stru_color = (internal_bull_bos or internal_bull_choch) ? color.lime : (internal_bear_bos or internal_bear_choch) ? color.red : color.gray
    table.cell(dashboard, 0, 7, "Internal Stru", text_color=color.white, text_size=size.small)
    table.cell(dashboard, 1, 7, int_stru_text, text_color=int_stru_color, text_size=size.small)
    
    // ── ROW 8: AI Conviction (State-Aware) ────────────────
    // Logic: If a trade is active, show the ENTRY conviction, otherwise show current bar
    prob_val = signal_recent ? active_signal_prob : math.max(probability_buy, probability_sell)
    dominant_score = signal_recent ? active_signal_score : math.max(buy_score, sell_score)
    
    // Harmonize conviction display with score — prevent misleading high % with low confluences
    conviction_aligned = (prob_val > 75 and dominant_score >= 5) or (prob_val > 85 and dominant_score >= 4)
    prob_display = conviction_aligned ? str.tostring(prob_val, "#") + "% ✓" : dominant_score < 4 ? str.tostring(prob_val, "#") + "% (Low Conf.)" : str.tostring(prob_val, "#") + "%"
    prob_color = conviction_aligned ? color.lime : prob_val > 75 and not conviction_aligned ? color.yellow : prob_val > 65 ? color.green : color.gray
    
    // If active, prepend "ENTRY: " to clarify
    final_prob_text = persistent_signal_type == "INVALIDATED ❌" ? "0% (VOIDED)" : signal_recent ? "Entry: " + prob_display : prob_display
    if persistent_signal_type == "INVALIDATED ❌"
        prob_color := color.gray
    
    table.cell(dashboard, 0, 8, "AI Conviction", text_color=color.white, text_size=size.small,
               tooltip="AI Probability Engine — how likely the trade succeeds.\n\n✓ = Conviction ALIGNED with confluence score (safe to trade)\n(Low Conf.) = High probability BUT low confluence count.\nThis means many factors weakly agree but no strong edge.\n\nIf a trade is active, this shows the conviction at the time of entry.")
    table.cell(dashboard, 1, 8, final_prob_text, text_color=prob_color, text_size=size.small)
    
    // ── ROW 9: Live Signal (State-Aware) ─────────────────
    // Logic: If a trade is active, show the trade status, otherwise show the current signal/score
    sig_text = ""
    sig_color = color.white
    
    if persistent_signal_type == "INVALIDATED ❌"
        sig_text := "⚠️ INVALIDATED — EXIT"
        sig_color := color.orange
    else if signal_recent and active_signal_dir != 0
        sig_text := active_signal_dir == 1 ? "🟢 ACTIVE BUY 💎" : "🔴 ACTIVE SELL 💎"
        sig_color := active_signal_dir == 1 ? color.lime : color.red
    else
        // Zero-Gap: Only show directional signal if it aligns with HTF OR is an A+ (Score >= 7) Setup
        bool high_quality_buy  = buy_score >= 5
        bool high_quality_sell = sell_score >= 5
        bool show_as_buy = (strong_buy or (high_quality_buy and htf_bull)) and (not strong_sell or htf_bull)
        bool show_as_sell = (strong_sell or (high_quality_sell and not htf_bull)) and (not strong_buy or not htf_bull)
        
        sig_text := show_as_buy ? "🚀 STRONG BUY" : show_as_sell ? "⚡ STRONG SELL" : "⏳ SCANNING..."
        sig_color := show_as_buy ? color.lime : show_as_sell ? color.red : color.white
        
    table.cell(dashboard, 0, 9, "Live Signal", text_color=color.white, text_size=size.small)
    table.cell(dashboard, 1, 9, sig_text, text_color=sig_color, text_size=size.small)

    // ── ROW 10: Trade Type (3-Tier: Swing / Intraday / Scalp) ─
    string type_text = ""
    color type_color = color.white
    
    if persistent_signal_type == "INVALIDATED ❌"
        type_text := "❌ VOIDED — No Active Trade"
        type_color := color.gray
    else if signal_recent and persistent_signal_type != "No Signal" and active_signal_dir != 0
        bool is_swing = str.contains(persistent_signal_type, "SWING")
        bool is_intra = str.contains(persistent_signal_type, "INTRADAY")
        type_text := is_swing ? "⚡ SWING (Locked)" : is_intra ? "📊 INTRADAY (Locked)" : "🔥 SCALP (Locked)"
        type_color := is_swing ? color.aqua : is_intra ? color.lime : color.orange
    else
        is_trend_aligned = (htf_bull and (strong_buy or buy_score >= 4)) or (not htf_bull and (strong_sell or sell_score >= 4))
        has_mtf = mtf_bullish_confluence or mtf_bearish_confluence
        type_text := (is_trend_aligned and has_mtf) ? "⚡ SWING (Multi-Session)" : is_trend_aligned ? "📊 INTRADAY (Session)" : "🔥 SCALP (Quick In/Out)"
        type_color := (is_trend_aligned and has_mtf) ? color.aqua : is_trend_aligned ? color.lime : color.orange

    table.cell(dashboard, 0, 10, "Trade Type", text_color=color.white, text_size=size.small,
               tooltip="SWING = HTF aligned + MTF confluence (hold multi-session)\nINTRADAY = HTF aligned (hold within session)\nSCALP = Counter-trend or no alignment (quick in/out)")
    table.cell(dashboard, 1, 10, type_text, text_color=type_color, text_size=size.small)

    // ── ROW 11: Next Setup ───────────────────────────────
    next_move = ""
    if htf_bull
        if near_pdl or sweep_pdl or sfp_bullish
            next_move := "Bullish Reversal"
        else if in_discount
            next_move := "Demand Entry"
        else
            next_move := "Trend Continue"
    else
        if near_pdh or sweep_pdh or sfp_bearish or is_reversal_imminent_bear
            next_move := "🔴 Bearish Reversal"
        else if in_premium
            next_move := "Supply Entry"
        else
            next_move := "Trend Continue"
    
    if persistent_signal_type == "INVALIDATED ❌"
        next_move := "⚠️ Wait for New Setup"
    table.cell(dashboard, 0, 11, "Next Setup", text_color=color.white, text_size=size.small)
    table.cell(dashboard, 1, 11, next_move, text_color=(next_move == "🔴 Bearish Reversal" or not htf_bull) ? color.red : color.lime, text_size=size.small)

    // ── ROW 12: PRO Action Plan (SFP/MSB-Aware) ──────────
    action_plan = "Stand Aside"
    if manual_reset
        action_plan := "Dashboard Reset Active 🧹"
    else if persistent_signal_type == "INVALIDATED ❌"
        action_plan := "❌ TRADE INVALIDATED — EXIT NOW"
    else if trade_lockdown
        action_plan := "MANAGE ACTIVE: " + (active_signal_dir == 1 ? "HOLD BUY 📈" : "HOLD SELL 📉")
    else if strong_buy
        action_plan := "🚀 ENTRY NOW — BUY (High Conviction)"
    else if strong_sell
        action_plan := "⚡ ENTRY NOW — SELL (High Conviction)"
    else if htf_bull and in_bu_ob
        action_plan := "BUY AT " + str.tostring(low_val, "#.#") + " (Demand Zone)"
    else if not htf_bull and in_be_ob
        action_plan := "SELL AT " + str.tostring(high_val, "#.#") + " (Supply Zone)"
    else if sfp_bullish and htf_bull
        action_plan := "SFP BUY Setup — Liq Swept ✓"
    else if sfp_bearish and htf_bear
        action_plan := "SFP SELL Setup — Liq Swept ✓"
    else if new_structure_break and market == 1
        action_plan := "MSB Bullish — Wait for Pullback"
    else if new_structure_break and market == -1
        action_plan := "MSB Bearish — Wait for Pullback"
    else if is_silver_bullet
        action_plan := "Silver Bullet Window — Watch"
    else if in_bu_fvg and htf_bull
        action_plan := "Bull FVG — Wait for Reaction"
    else if in_be_fvg and htf_bear
        action_plan := "Bear FVG — Wait for Reaction"
    else if is_reversal_imminent_bear
        action_plan := "⚠️ REVERSAL IMMINENT (Supply Trap)"
    else if is_reversal_imminent_bull
        action_plan := "⚠️ REVERSAL IMMINENT (Demand Trap)"
    else
        action_plan := "Wait for Zone Touch ⏳"

    color action_color = (is_reversal_imminent_bear or is_reversal_imminent_bull) ? (is_reversal_imminent_bear ? color.red : color.lime) : color.yellow
    table.cell(dashboard, 0, 12, "PRO Action", text_color=color.white, text_size=size.small, bgcolor=color.new(color.gray, 10))
    table.cell(dashboard, 1, 12, action_plan, text_color=action_color, text_size=size.small, bgcolor=color.new(color.gray, 10))

    // ── ROW 13: SL / TP Targets (HARDENED) ──────────────
    string sl_tp_text = "Scanning for Targets..."
    color sl_tp_color = color.gray
    color sl_tp_bg    = color.new(color.gray, 90)
    
    if persistent_signal_type == "INVALIDATED ❌"
        sl_tp_text := "❌ Trade Voided — Targets Cleared"
        sl_tp_color := color.gray
        sl_tp_bg := color.new(color.gray, 90)
    else if active_signal_dir != 0 and signal_recent
        // Use FROZEN signal targets to prevent fluctuations
        float target_ep  = frozen_ep
        float target_sl  = frozen_sl
        float target_tp1 = frozen_tp1
        float target_tp2 = frozen_tp2
        
        // Determine mode from persistent_signal_type
        bool is_swing = str.contains(persistent_signal_type, "SWING")
        bool is_intra = str.contains(persistent_signal_type, "INTRADAY")
        string mode_label = is_swing ? "💎 SWING" : is_intra ? "📊 INTRA" : "🔥 SCALP"
        
        // Show 2 targets for swing/intra, 1 for scalp
        if is_swing or is_intra
            sl_tp_text := mode_label + " | EP: " + str.tostring(target_ep, "#.#") + " | SL: " + str.tostring(target_sl, "#.#") + " | TP1: " + str.tostring(target_tp1, "#.#") + " | TP2: " + str.tostring(target_tp2, "#.#")
        else
            sl_tp_text := mode_label + " | EP: " + str.tostring(target_ep, "#.#") + " | SL: " + str.tostring(target_sl, "#.#") + " | TP: " + str.tostring(target_tp1, "#.#")
            
        sl_tp_color := active_signal_dir == 1 ? color.lime : color.red
        
        // --- COUNTER-TREND WARNING ---
        sl_tp_bg := active_signal_dir == 1 ? color.new(color.green, 90) : color.new(color.red, 90)
    else
        // Generic projection if no active signal (matches HTF Bias)
        float proj_ep = close
        float proj_tp = htf_bull ? math.max(pdh, high + atr_val * 2.5) : math.min(pdl, low - atr_val * 2.5)
        float proj_sl = htf_bull ? low - (atr_val * 2) : high + (atr_val * 2)
        // Correcting Sell targets (TP must be below EP)
        if not htf_bull and proj_tp > proj_ep
            proj_tp := proj_ep - (proj_sl - proj_ep)
        
        sl_tp_text := (htf_bull ? "🟢 BUY " : "🔴 SELL ") + "EP: MKT (" + str.tostring(proj_ep, "#.#") + ") | SL: " + str.tostring(proj_sl, "#.#") + " | TP: " + str.tostring(proj_tp, "#.#")
        sl_tp_color := htf_bull ? color.lime : color.red
        sl_tp_bg    := htf_bull ? color.new(color.lime, 90) : color.new(color.red, 90)

    table.cell(dashboard, 0, 13, "SL / TP Mode", text_color=color.white, text_size=size.small, bgcolor=sl_tp_bg)
    table.cell(dashboard, 1, 13, sl_tp_text, text_color=sl_tp_color, text_size=size.small, bgcolor=sl_tp_bg)

    // ── ROW 14: Adaptive ATR / K-Means Factor ────────────
    if use_adaptive_atr
        dash_factor = current_adaptive_factor
        factor_color = dash_factor < 2.0 ? color.green : dash_factor < 3.0 ? color.yellow : color.red
        condition_text = dash_factor < 2.0 ? "Low Vol 📉" : dash_factor < 3.0 ? "Normal 📊" : "High Vol 📈"
        
        table.cell(dashboard, 0, 14, "K-Means ATR", text_color=color.white, text_size=size.small)
        table.cell(dashboard, 1, 14, str.tostring(dash_factor, "#.##") + "x " + condition_text, 
                   text_color=factor_color, text_size=size.small,
                   tooltip="K-means clustered optimal ATR multiplier\nGreen=Tight stops, Yellow=Medium, Red=Wide stops")
    else
        table.cell(dashboard, 0, 14, "ATR Factor", text_color=color.white, text_size=size.small)
        table.cell(dashboard, 1, 14, "Disabled", text_color=color.gray, text_size=size.small)

    // ── ROW 15: Volume Profile POC ───────────────────────
    if use_volume_profile
        poc_dist_pips = not na(vp_poc_level) ? (close - vp_poc_level) * 10 : 0
        poc_cell_text = not na(vp_poc_level) ? (poc_dist_pips > 0 ? "+" : "") + str.tostring(poc_dist_pips, "#.#") + " pips" : "Calculating..."
        poc_cell_color = not na(vp_poc_level) and math.abs(close - vp_poc_level) < zone_dist ? color.yellow : color.white
        
        table.cell(dashboard, 0, 15, "POC Distance", text_color=color.white, text_size=size.small,
                   tooltip="Point of Control = highest-volume price\nYellow = price is near POC (institutional level)")
        table.cell(dashboard, 1, 15, poc_cell_text, text_color=poc_cell_color, text_size=size.small)
    else
        table.cell(dashboard, 0, 15, "Volume Profile", text_color=color.white, text_size=size.small)
        table.cell(dashboard, 1, 15, "Disabled", text_color=color.gray, text_size=size.small)

    // ── ROW 16: Value Area ───────────────────────────────
    if use_volume_profile
        va_text = inside_value_area ? "Inside VA ✓" : in_discount_va ? "Below VA (Discount)" : in_premium_va ? "Above VA (Premium)" : "Outside VA"
        va_disp_color = inside_value_area ? color.green : in_discount_va ? color.aqua : in_premium_va ? color.orange : color.gray
        
        table.cell(dashboard, 0, 16, "Value Area", text_color=color.white, text_size=size.small,
                   tooltip="Value Area = 68% of volume (fair value zone)")
        table.cell(dashboard, 1, 16, va_text, text_color=va_disp_color, text_size=size.small)
    else
        table.cell(dashboard, 0, 16, "Value Area", text_color=color.white, text_size=size.small)
        table.cell(dashboard, 1, 16, "—", text_color=color.gray, text_size=size.small)

    // ── ROW 17: Area of Interest ─────────────────────────
    if use_aoe
        aoe_status_text = aoe_breakout_bull ? "Bullish Breakout 🚀" : aoe_breakout_bear ? "Bearish Breakdown ⚡" : inside_aoe ? "Inside AOE 📦" : "Outside AOE"
        aoe_status_color = aoe_breakout_bull ? color.lime : aoe_breakout_bear ? color.red : inside_aoe ? color.yellow : color.gray
        
        table.cell(dashboard, 0, 17, "Area of Interest", text_color=color.white, text_size=size.small,
                   tooltip="50-bar consolidation zone\nBreakout = institutional accumulation complete")
        table.cell(dashboard, 1, 17, aoe_status_text, text_color=aoe_status_color, text_size=size.small)
    else
        table.cell(dashboard, 0, 17, "AOE", text_color=color.white, text_size=size.small)
        table.cell(dashboard, 1, 17, "Disabled", text_color=color.gray, text_size=size.small)

    // ── ROW 18: SFP (Swing Failure Pattern) ──────────────
    // SFP = Price sweeps a previous high/low to grab liquidity, then reverses
    // This is a HIGH-CONVICTION reversal signal used by institutional traders
    sfp_text = sfp_bullish ? "BULLISH SFP ✓ (Buy Setup)" : sfp_bearish ? "BEARISH SFP ✓ (Sell Setup)" : sfp_recent and last_sfp_dir == 1 ? "Bull SFP (" + str.tostring(sfp_bars_ago) + " bars ago)" : sfp_recent and last_sfp_dir == -1 ? "Bear SFP (" + str.tostring(sfp_bars_ago) + " bars ago)" : "No SFP"
    sfp_color = sfp_bullish ? color.lime : sfp_bearish ? color.red : sfp_recent and last_sfp_dir == 1 ? color.new(color.lime, 40) : sfp_recent and last_sfp_dir == -1 ? color.new(color.red, 40) : color.gray
    table.cell(dashboard, 0, 18, "SFP", text_color=color.white, text_size=size.small,
               tooltip="Swing Failure Pattern (SFP)\n━━━━━━━━━━━━━━━━━━━━━━━━\nWHAT: Price breaks a previous swing high/low\nbut FAILS to hold and reverses back.\n\nWHY IT MATTERS: Smart money sweeps stop-losses\n(liquidity) then reverses. This traps retail traders.\n\n✅ BULLISH SFP = Price dips below prior low then\ncloses back above → BUY signal (lows were swept)\n\n❌ BEARISH SFP = Price spikes above prior high then\ncloses back below → SELL signal (highs were swept)\n\n🎯 ACTION: When SFP aligns with HTF bias,\nit's one of the highest-conviction entry signals.\n\nPersistence: Shown for 20 bars after detection.")
               
    table.cell(dashboard, 1, 18, sfp_text, text_color=sfp_color, text_size=size.small)

    // ── ROW 19: MSB (Market Structure Break) ─────────────
    // MSB = When price breaks a significant swing point, confirming trend change
    msb_text = msb_recent and last_msb_dir == 1 ? "Bull MSB (" + str.tostring(msb_bars_ago) + " bars ago)" : msb_recent and last_msb_dir == -1 ? "Bear MSB (" + str.tostring(msb_bars_ago) + " bars ago)" : "No MSB"
    msb_color = msb_recent and last_msb_dir == 1 ? color.new(color.lime, 40) : msb_recent and last_msb_dir == -1 ? color.new(color.red, 40) : color.gray
    if new_structure_break
        if last_msb_dir == 1
            msb_text := "BULLISH MSB ▲ (Trend Up)"
            msb_color := color.lime
        else
            msb_text := "BEARISH MSB ▼ (Trend Down)"
            msb_color := color.red

    table.cell(dashboard, 0, 19, "MSB", text_color=color.white, text_size=size.small,
               tooltip="Market Structure Break (MSB)\n━━━━━━━━━━━━━━━━━━━━━━━━\nWHAT: Price breaks through a key swing high\nor swing low, confirming a structural trend shift.\n\nAlso known as: Break of Structure (BoS)\n\nWHY IT MATTERS: MSB confirms the trend has\nchanged at the structural level. All smart money\nmodels require MSB before entering trades.\n\n▲ BULLISH MSB = Higher high confirmed → Uptrend\n▼ BEARISH MSB = Lower low confirmed → Downtrend\n\n🎯 ACTION: After MSB, wait for a pullback into\nan Order Block or FVG for a high-probability entry.\nDO NOT chase — let price come to your zone.\n\nPersistence: Shown for 20 bars after detection.")
               
    table.cell(dashboard, 1, 19, msb_text, text_color=msb_color, text_size=size.small)

    // ── ROW 20: Active Signal Type ───────────────────────
    // Using persistent state so the signal type remains visible after the entry candle
    table.cell(dashboard, 0, 20, "Signal Type", text_color=color.white, text_size=size.small,
               tooltip="Which signal tier is currently active:\n\n⚡ SWING = Highest quality. HTF + MTF aligned.\nHold for multiple sessions. Target: 2.5R+\n\n📊 INTRADAY = Mid quality. HTF aligned.\nHold within the session. Target: 2.0R\n\n🔥 SCALP = Quick trade. No HTF alignment.\nIn and out within 1-3 bars. Target: 1.5R")
    table.cell(dashboard, 1, 20, persistent_signal_type, text_color=persistent_signal_color, text_size=size.small)

    // ── ROW 21: Confluence Count ─────────────────────────
    max_score = math.max(buy_score, sell_score)
    conf_count_text = str.tostring(max_score) + " confluences"
    conf_count_color = max_score >= 8 ? color.lime : max_score >= 5 ? color.green : max_score >= 3 ? color.yellow : color.gray
    conf_quality = max_score >= 8 ? " (A+ Setup)" : max_score >= 5 ? " (Good)" : max_score >= 3 ? " (Weak)" : " (Skip)"
    
    if persistent_signal_type == "INVALIDATED ❌"
        conf_count_text := "0 confluences (Voided)"
        conf_count_color := color.gray
        conf_quality := ""
        
    table.cell(dashboard, 0, 21, "Confluences", text_color=color.white, text_size=size.small,
               tooltip="Total number of factors confirming the trade.\nMore confluences = higher probability.\n\n8+ = A+ Setup (rare, high conviction)\n5-7 = Good trade (proceed with caution)\n3-4 = Weak (only scalp if experienced)\n0-2 = Skip (no edge)")
    table.cell(dashboard, 1, 21, conf_count_text + conf_quality, text_color=(persistent_signal_type == "INVALIDATED ❌" ? color.gray : sig_color == color.white ? conf_count_color : sig_color), text_size=size.small)

    // ── ROW 22: Beginner Guide (What To Do Next) ─────────
    guide_text = "Stand Aside — No Edge"
    guide_color = color.gray
    
    // Priority 0: Emergency Exit for Invalidated Trades
    if persistent_signal_type == "INVALIDATED ❌"
        guide_text := "❌ Signal Invalidated — Close Position"
        guide_color := color.red
    
    // Priority 1: Instant Entry Instructions (3-Tier Signals)
    else if strong_buy and (not strong_sell or htf_bull)
        if swing_buy
            guide_text := "✅ Place BUY now. Hold for TP2"
            guide_color := color.lime
        else if intraday_buy
            guide_text := "✅ Place BUY now. Close at session end"
            guide_color := color.lime
        else if scalp_buy
            guide_text := "✅ Quick BUY. Take TP1 and exit"
            guide_color := color.lime
    else if strong_sell and (not strong_buy or not htf_bull)
        if swing_sell
            guide_text := "✅ Place SELL now. Hold for TP2"
            guide_color := color.red
        else if intraday_sell
            guide_text := "✅ Place SELL now. Close at session end"
            guide_color := color.red
        else if scalp_sell
            guide_text := "✅ Quick SELL. Take TP1 and exit"
            guide_color := color.red
    
    // Priority 2: Trade Management (for active trades within the window)
    else if signal_recent and persistent_signal_type != "No Signal" and persistent_signal_type != "INVALIDATED ❌" and active_signal_dir != 0
        // Intelligence: Identify potential obstacles (FVG/OB in the way) - PROACTIVE detection
        // Check if price is within 0.1% of an obstacle
        near_be_fvg = not na(be_bot) and close > be_bot - (close * 0.001) and close < be_top
        near_be_ob = not na(be_bot) and close > be_bot - (close * 0.001) and close < be_top
        near_bu_fvg = not na(bu_top) and close < bu_top + (close * 0.001) and close > bu_bot
        near_bu_ob = not na(bu_top) and close < bu_top + (close * 0.001) and close > bu_bot
        
        obstacle_found = (active_signal_dir == 1 and (in_be_ob or in_be_fvg or near_be_fvg or near_be_ob or near_resistance)) or (active_signal_dir == -1 and (in_bu_ob or in_bu_fvg or near_bu_fvg or near_bu_ob or near_support))
        
        // Intelligence: Risk/Reward check for Breakeven
        bool is_in_profit = (active_signal_dir == 1 and close > frozen_ep) or (active_signal_dir == -1 and close < frozen_ep)
        float current_rr = is_in_profit ? math.abs(close - frozen_ep) / frozen_risk : 0
        
        if active_signal_dir == 1
            if is_reversal_imminent_bear
                guide_text := "🛑 REVERSAL DETECTED — EXIT BUY NOW"
                guide_color := color.red
            else if current_rr >= 1.0
                guide_text := "✅ 1:1 Reached — Move SL to Breakeven"
                guide_color := color.aqua
            else if obstacle_found
                guide_text := "⚠️ Resistance Ahead — Watch for Rejection"
                guide_color := color.orange
            else if close > ema_fast
                guide_text := "💪 Trend Strong — Hold to TP1"
                guide_color := color.lime
            else
                guide_text := "🎯 Trade Active — Manage Position"
                guide_color := color.lime
        else // SELL
            if is_reversal_imminent_bull
                guide_text := "🟢 REVERSAL DETECTED — EXIT SELL NOW"
                guide_color := color.lime
            else if current_rr >= 1.0
                guide_text := "✅ 1:1 Reached — Move SL to Breakeven"
                guide_color := color.aqua
            else if obstacle_found
                guide_text := "⚠️ Support Ahead — Watch for Rejection"
                guide_color := color.orange
            else if close < ema_fast
                guide_text := "💪 Trend Strong — Hold to TP1"
                guide_color := color.red
            else
                guide_text := "🎯 Trade Active — Manage Position"
                guide_color := color.red
        
    // Priority 3: Setup Identification (SFP, MSB, Zones)
    else if sfp_bullish and htf_bull
        guide_text := "🔍 SFP detected. Wait for candle close"
        guide_color := color.aqua
    else if sfp_bearish and htf_bear
        guide_text := "🔍 SFP detected. Wait for candle close"
        guide_color := color.aqua
    else if sfp_recent and last_sfp_dir == 1 and htf_bull
        guide_text := "🔍 Recent Bull SFP. Watch for BUY"
        guide_color := color.lime
    else if sfp_recent and last_sfp_dir == -1 and htf_bear
        guide_text := "🔍 Recent Bear SFP. Watch for SELL"
        guide_color := color.red
    else if in_bu_ob and htf_bull
        guide_text := "⏳ In Demand Zone. Set limit BUY"
        guide_color := color.green
    else if in_be_ob and htf_bear
        guide_text := "⏳ In Supply Zone. Set limit SELL"
        guide_color := color.green
    else if new_structure_break
        guide_text := "📐 MSB fired. Wait for pullback"
        guide_color := color.aqua
    else if msb_recent and last_msb_dir == 1 and htf_bull
        guide_text := "📐 Recent Bull MSB. Wait for pullback"
        guide_color := color.lime
    else if msb_recent and last_msb_dir == -1 and htf_bear
        guide_text := "📐 Recent Bear MSB. Wait for pullback"
        guide_color := color.red
    else if is_silver_bullet
        guide_text := "🎯 SB Window. Watch for volatility"
        guide_color := color.yellow
    else if not na(nearest_bu_zone) and htf_bull
        guide_text := "⏳ Wait for Demand @ " + str.tostring(nearest_bu_zone, "#.##")
        guide_color := color.new(color.green, 30)
    else if not na(nearest_be_zone) and htf_bear
        guide_text := "⏳ Wait for Supply @ " + str.tostring(nearest_be_zone, "#.##")
        guide_color := color.new(color.red, 30)
    else if not in_session
        guide_text := "💤 Outside session. Do NOT trade"
        guide_color := color.gray
        
    else
        guide_text := "⏳ Scanning... Wait for setup"
        guide_color := color.white

    table.cell(dashboard, 0, 22, "📘 Next Step", text_color=color.white, text_size=size.small, bgcolor=color.new(#1a237e, 20),
               tooltip="BEGINNER GUIDE — What to do RIGHT NOW:\n\nThis row tells you the exact next action.\nFollow it step by step:\n\n✅ = Signal is live. Place the trade.\n⏳ = Setup forming. Wait patiently.\n🔍 = Pattern detected. Confirm with candle close.\n📐 = Structure changed. Wait for pullback.\n💤 = Outside trading hours. Rest.\n\nGOLDEN RULE: Only trade when this row says ✅")
    table.cell(dashboard, 1, 22, guide_text, text_color=guide_color, text_size=size.small, bgcolor=color.new(#1a237e, 20))

    // ── ROW 23: Final Verdict (Institutional Intelligence) ────────────────────
    string verdict_text = "Wait for Setup ⏳"
    color verdict_color = color.gray
    
    // Institutional Decision Logic
    bool is_prime_buy = htf_bull and buy_score >= 6 and dxy_bearish
    bool is_prime_sell = not htf_bull and sell_score >= 6 and not dxy_bearish
    
    bool is_good_buy = htf_bull and buy_score >= 5
    bool is_good_sell = not htf_bull and sell_score >= 5
    
    bool is_contrarian = (buy_score >= 5 or sell_score >= 5) // High score but against HTF
    
    // Priority 0: Invalidation Override
    if persistent_signal_type == "INVALIDATED ❌"
        verdict_text := "❌ TRADE INVALIDATED — EXIT ALL POSITIONS"
        verdict_color := color.red
    // Priority 1: Active Trade Awareness
    else if signal_recent and persistent_signal_type != "No Signal" and active_signal_dir != 0
        verdict_text := "✅ ACTIVE: " + persistent_signal_type + " @ " + str.tostring(frozen_ep, "#.#") + " — Hold"
        verdict_color := color.lime
    // Priority 2: New Opportunities (Synthesis of Score + Bias + DXY)
    else if is_prime_buy
        verdict_text := "💎 BUY SWING @ MKT | SL: " + str.tostring(buy_sl, "#.#") + " | TP: " + str.tostring(buy_tp1, "#.#")
        verdict_color := color.lime
    else if is_prime_sell
        verdict_text := "💎 SELL SWING @ MKT | SL: " + str.tostring(sell_sl, "#.#") + " | TP: " + str.tostring(sell_tp1, "#.#")
        verdict_color := color.red
    else if is_good_buy
        verdict_text := "📊 BUY INTRA @ MKT | SL: " + str.tostring(buy_sl, "#.#") + " | TP: " + str.tostring(buy_tp1, "#.#")
        verdict_color := color.lime
    else if is_good_sell
        verdict_text := "📊 SELL INTRA @ MKT | SL: " + str.tostring(sell_sl, "#.#") + " | TP: " + str.tostring(sell_tp1, "#.#")
        verdict_color := color.red
    else if is_contrarian
        verdict_text := "🔥 QUICK SCALP | Score: " + str.tostring(math.max(buy_score, sell_score)) + "/8"
        verdict_color := color.yellow
    else if buy_score < 4 and sell_score < 4
        if htf_bull
            verdict_text := "⏳ CONSOLIDATION — Wait for Bullish Pullback"
            verdict_color := color.lime
        else if htf_bear
            verdict_text := "⏳ CONSOLIDATION — Wait for Bearish Pullback"
            verdict_color := color.red
        else
            verdict_text := "❌ NO EDGE - DO NOT TRADE"
            verdict_color := color.red
    else
        verdict_text := "⏳ WAIT FOR " + (htf_bull ? "BULLISH" : "BEARISH") + " SETUP"
        verdict_color := htf_bull ? color.lime : color.red

    table.cell(dashboard, 0, 23, "🏆 Final Verdict", text_color=color.white, text_size=size.small, bgcolor=color.new(color.purple, 30))
    table.cell(dashboard, 1, 23, verdict_text, text_color=verdict_color, text_size=size.small, bgcolor=color.new(verdict_color, 90))

// =====================================================
// BOX LIMIT MANAGEMENT (Task 19.3) + ENHANCED FOR 15M
// =====================================================

// Monitor total box count and implement aggressive cleanup if approaching limit
total_boxes = array.size(bu_ob_boxes) + array.size(be_ob_boxes) + array.size(bu_bb_boxes) + array.size(be_bb_boxes) + array.size(bu_fvg_boxes) + array.size(be_fvg_boxes)

// More aggressive cleanup threshold for 15m charts
cleanup_threshold = aggressive_cleanup ? 100 : 300
cleanup_target    = aggressive_cleanup ? 60  : 200

// Aggressive cleanup when approaching threshold
if total_boxes >= cleanup_threshold
    // Remove oldest boxes first (FIFO)
    while total_boxes > cleanup_target and total_boxes > 0
        // Prioritize removing FVGs first (less important than order blocks)
        if array.size(bu_fvg_boxes) > 0
            f_delete_box_with_age(bu_fvg_boxes, bu_fvg_ages)
        if array.size(be_fvg_boxes) > 0
            f_delete_box_with_age(be_fvg_boxes, be_fvg_ages)
        
        // Then remove breaker blocks
        if show_breaker_blocks
            if array.size(bu_bb_boxes) > 0
                f_delete_box_with_age(bu_bb_boxes, bu_bb_ages)
            if array.size(be_bb_boxes) > 0
                f_delete_box_with_age(be_bb_boxes, be_bb_ages)
        
        // Finally remove order blocks if still over limit
        if array.size(bu_ob_boxes) > max_boxes_per_type
            f_delete_box_with_age(bu_ob_boxes, bu_ob_ages)
        if array.size(be_ob_boxes) > max_boxes_per_type
            f_delete_box_with_age(be_ob_boxes, be_ob_ages)
        
        // Recalculate total
        total_boxes := array.size(bu_ob_boxes) + array.size(be_ob_boxes) + 
                       array.size(bu_bb_boxes) + array.size(be_bb_boxes) + 
                       array.size(bu_fvg_boxes) + array.size(be_fvg_boxes)

// =====================================================
// ADAPTIVE ATR DEBUG DISPLAY (Optional - for testing)
// =====================================================
if show_adaptive_debug and use_adaptive_atr and barstate.islast
    var table debug_table = table.new(position.top_left, 3, 10, 
                                      bgcolor=color.new(color.black, 10), 
                                      border_width=1)
    
    table.cell(debug_table, 0, 0, "Factor", text_color=color.white, text_size=size.tiny)
    table.cell(debug_table, 1, 0, "Performance", text_color=color.white, text_size=size.tiny)
    table.cell(debug_table, 2, 0, "Status", text_color=color.white, text_size=size.tiny)
    
    for i = 0 to math.min(array.size(atr_trackers) - 1, 8)
        tracker = array.get(atr_trackers, i)
        is_best = tracker.factor == adaptive_best_factor
        
        table.cell(debug_table, 0, i + 1, str.tostring(tracker.factor, "#.#"), 
                   text_color=color.white, text_size=size.tiny)
        table.cell(debug_table, 1, i + 1, str.tostring(tracker.perf, "#.##"), 
                   text_color=tracker.perf > 0 ? color.green : color.red, text_size=size.tiny)
        table.cell(debug_table, 2, i + 1, is_best ? "✓ BEST" : "", 
                   text_color=color.yellow, text_size=size.tiny)

// =====================================================
// ALERT SYSTEM (Task 20)
// =====================================================

alertcondition(ta.change(market) != 0, "MSB", "Market Structure Break")
alertcondition(strong_buy, "Strong Buy", "Strong Buy Signal")
alertcondition(strong_sell, "Strong Sell", "Strong Sell Signal")
alertcondition(swing_buy, "Swing Buy", "Swing Buy Signal — HTF + MTF aligned, hold multi-session")
alertcondition(swing_sell, "Swing Sell", "Swing Sell Signal — HTF + MTF aligned, hold multi-session")
alertcondition(intraday_buy, "Intraday Buy", "Intraday Buy Signal — HTF aligned, close at session end")
alertcondition(intraday_sell, "Intraday Sell", "Intraday Sell Signal — HTF aligned, close at session end")
alertcondition(scalp_buy, "Scalp Buy", "Scalp Buy Signal — Quick in/out, take TP1")
alertcondition(scalp_sell, "Scalp Sell", "Scalp Sell Signal — Quick in/out, take TP1")
alertcondition(sniper_buy, "Sniper Buy", "Sniper Buy Signal")
alertcondition(sniper_sell, "Sniper Sell", "Sniper Sell Signal")
alertcondition(sfp_bullish, "SFP Bullish", "Swing Failure Pattern — Bullish reversal after liquidity sweep")
alertcondition(sfp_bearish, "SFP Bearish", "Swing Failure Pattern — Bearish reversal after liquidity sweep")
alertcondition(near_poc, "Near POC", "Price near Point of Control — institutional level")
alertcondition(aoe_breakout_bull, "AOE Bullish Breakout", "Bullish breakout from Area of Interest consolidation")
alertcondition(aoe_breakout_bear, "AOE Bearish Breakdown", "Bearish breakdown from Area of Interest consolidation")

